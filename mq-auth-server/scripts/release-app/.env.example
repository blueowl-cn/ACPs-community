# mq-auth-server 环境变量配置
# 非敏感配置项已迁移至 config/*.toml，此处仅保留敏感/部署相关变量

# 环境选择（决定加载哪个 TOML 配置文件：development / testing / production）
APP_ENV=production

# 宿主机证书目录（发布约定：整个目录只读挂载到容器内 /certs）
CERTS_HOST_DIR=/srv/acps/mq-auth-server/certs

# RabbitMQ Management API 密码（必需）
RABBITMQ_MGMT_PASS=change-me-to-strong-password

# RabbitMQ Management API 地址
RABBITMQ_MGMT_URL=http://stage-rabbitmq:15672

# Redis 连接（stage-infra Redis 只开 TLS 端口，必须使用 rediss://）
REDIS_URL=rediss://:CHANGE_ME_REDIS_PASSWORD@stage-redis:6379/2
# Redis TLS CA 证书路径（容器内路径，与 TLS_CA_CERT_FILE 相同）
REDIS_TLS_CA_CERT=/certs/acps-root-ca.pem
# 当前证书采用 AIC 语义 CN/SAN，不与 stage-redis 主机名匹配，默认关闭主机名校验
REDIS_TLS_CHECK_HOSTNAME=false

# TLS 证书（mTLS 双向认证）
TLS_CERT_FILE=/certs/server.pem
TLS_KEY_FILE=/certs/server.key
TLS_CA_CERT_FILE=/certs/acps-root-ca.pem

# 健康检查 / 冒烟测试客户端证书（生产 / 测试环境必需）
HEALTHCHECK_TLS_CERT_FILE=/certs/client.pem
HEALTHCHECK_TLS_KEY_FILE=/certs/client.key
HEALTHCHECK_TLS_CA_CERT_FILE=/certs/acps-root-ca.pem

# 推荐的宿主机证书布局（相对于 CERTS_HOST_DIR）：
#   server.pem
#   server.key
#   acps-root-ca.pem
#   client.pem
#   client.key
