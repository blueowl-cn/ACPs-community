set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

project_name := "mq-auth-server"
dev_infra_script := "../acps-infra/dev-infra/dev-infra.sh"
dev_pki_script := "../acps-infra/dev-infra/dev-cert.sh"
default_healthcheck_client_aic := "1.2.156.3088.1.1.SC64YN.Z5LSGY.1.0NMQ"
app_pid_file := "logs/mq-auth-server.pid"
app_log_file := "logs/mq-auth-server.log"
group_health_url := "https://localhost:9007/health"

default:
    @just help

help:
    @echo "mq-auth-server Just 命令"
    @echo ""
    @echo "用法："
    @echo "  just app [action] [args...]"
    @echo "  just test [action] [args...]"
    @echo "  just qa [action] [args...]"
    @echo "  just package [action] [args...]"
    @echo "  just infra [action] [args...]"
    @echo "  just doctor"
    @echo "  just prep [action] [args...]"
    @echo ""
    @echo "app：本地应用生命周期"
    @echo "  bootstrap        建立开发环境（infra up/wait + prep env + prep sync + prep hooks + prep certs + prep migrate app[no-op]）"
    @echo "  start            后台启动服务（默认动作），日志写入 logs/mq-auth-server.log"
    @echo "  start bg         显式后台启动服务"
    @echo "  start fg         前台启动服务，占用当前 console"
    @echo "  stop             停止后台实例"
    @echo "  status           查看后台实例状态"
    @echo "  logs             查看后台日志末尾 200 行"
    @echo "  logs follow      持续跟随后台日志"
    @echo "  restart          重启受管后台实例"
    @echo ""
    @echo "test：测试入口"
    @echo "  bootstrap        建立测试环境（infra up/wait + prep env + prep sync + prep hooks + prep certs + prep migrate test[no-op]）"
    @echo "  unit             运行单元测试；支持透传 pytest 参数"
    @echo "  coverage         运行单元测试覆盖率门禁（fail-under=70）"
    @echo "  integration      执行测试环境只读预检后运行集成测试"
    @echo "  e2e              执行测试环境只读预检，临时拉起真实服务实例后运行端到端测试"
    @echo "  all              依次执行 unit -> integration -> e2e"
    @echo ""
    @echo "qa：代码质量入口"
    @echo "  lint             执行 ruff format --check + ruff check"
    @echo "  fmt              执行 ruff format ."
    @echo "  type             执行 mypy app/（兼容别名）"
    @echo "  type-app         对 app/ 执行 mypy"
    @echo "  type-tests       对 tests/ 执行 mypy"
    @echo "  security         执行 Bandit 安全扫描"
    @echo "  audit            执行 pip-audit 依赖漏洞扫描"
    @echo "  full             执行 lint -> type-app -> type-tests -> security"
    @echo "  fix              执行 format + ruff check --fix"
    @echo "  precommit        执行 pre-commit run --all-files"
    @echo "  all              依次执行 fix -> precommit"
    @echo ""
    @echo "package：原生 wheel 运行包构建"
    @echo "  wheel            构建在线运行包（默认动作）"
    @echo "  wheel offline    构建离线运行包（额外包含 wheelhouse/）"
    @echo ""
    @echo "infra：共享依赖管理"
    @echo "  status [service...] [--format=tsv]   查看共享依赖状态"
    @echo "  up [service...]                      启动共享依赖，默认 redis rabbitmq"
    @echo "  wait [service...]                    等待共享依赖就绪"
    @echo "  down                                 停止共享依赖"
    @echo "  logs [service...] [--follow]         查看共享依赖日志"
    @echo "  reset [service...] [--volumes --yes] 修复性重建共享依赖"
    @echo "  doctor                               检查共享 infra 环境"
    @echo ""
    @echo "doctor：本地开发环境检查"
    @echo "  检查 uv / .venv Python / just / openssl / .env / uv sync 状态 / dev-infra / Redis / RabbitMQ 健康状态"
    @echo "  并提示 e2e mTLS 开发证书是否齐备（缺失时可执行 just prep certs 按本仓声明签发）"
    @echo ""
    @echo "prep：维护与局部修复动作"
    @echo "  env           缺失时根据 .env.example 生成 .env"
    @echo "  sync          执行 uv sync"
    @echo "  hooks         安装/更新 pre-commit 与 commit-msg hooks"
    @echo "  certs [reset] 委托共享开发 PKI 按本仓声明签发开发证书；传 reset 时先清理本仓证书再重签"
    @echo "  migrate [app|test]  无数据库项目，显式 skip"
    @echo ""
    @echo "常用示例："
    @echo "  just app bootstrap"
    @echo "  just app"
    @echo "  just app start fg"
    @echo "  just test bootstrap"
    @echo "  just test e2e"
    @echo "  just package wheel"
    @echo "  just package wheel offline"
    @echo "  just qa"

infra action='status' *args:
    @{{ dev_infra_script }} {{ action }} {{ args }}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0
    infra_ok=1
    skip_dotenv_check="${SKIP_DOTENV_DOCTOR:-0}"
    skip_rabbitmq_mgmt_pass_check="${SKIP_RABBITMQ_MGMT_PASS_DOCTOR:-0}"
    skip_shared_infra_check="${SKIP_SHARED_INFRA_DOCTOR:-0}"

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    check_service_status() {
        local service_name="$1"
        local status_output=""

        if ! status_output="$(just infra status "${service_name}" --format=tsv 2>"${tmpfile}")"; then
            echo "[ERROR] 无法读取共享 ${service_name} 状态。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
            return
        fi

        if [[ -z "${status_output}" ]]; then
            echo "[ERROR] 共享 ${service_name} 状态输出为空。" >&2
            issues=$((issues + 1))
            return
        fi

        IFS=$'\t' read -r service _mode state health _ports <<< "${status_output%%$'\n'*}"
        if [[ "${service}" != "${service_name}" ]]; then
            echo "[ERROR] 共享 ${service_name} 状态输出格式异常：${status_output}" >&2
            issues=$((issues + 1))
            return
        fi

        if [[ "${state}" != "running" ]]; then
            echo "[ERROR] 共享 ${service_name} 未运行（state=${state}）。请先执行 just infra up ${service_name}。" >&2
            issues=$((issues + 1))
        fi

        if [[ "${health}" != "healthy" ]]; then
            echo "[ERROR] 共享 ${service_name} 未健康（health=${health}）。请先执行 just infra wait ${service_name}。" >&2
            issues=$((issues + 1))
        fi
    }

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    elif ! uv run --no-sync python -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 14) else 1)' >"${tmpfile}" 2>&1; then
        echo "[ERROR] .venv Python 版本不满足 pyproject.toml 要求（需要 >=3.14）。请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if ! command -v openssl >/dev/null 2>&1; then
        echo "[ERROR] 未找到 openssl；just prep certs 依赖共享开发 PKI 脚本使用 openssl。" >&2
        issues=$((issues + 1))
    fi

    if [[ -f .env ]]; then
        load_dotenv
    elif [[ "${skip_dotenv_check}" == "1" ]]; then
        echo "[INFO]  跳过 .env 检查（SKIP_DOTENV_DOCTOR=1）。"
    else
        echo "[ERROR] 未找到 .env，请先执行 just prep env。" >&2
        issues=$((issues + 1))
    fi

    if [[ "${skip_rabbitmq_mgmt_pass_check}" == "1" ]]; then
        echo "[INFO]  跳过 RABBITMQ_MGMT_PASS 检查（SKIP_RABBITMQ_MGMT_PASS_DOCTOR=1）。"
    elif [[ -z "${RABBITMQ_MGMT_PASS:-}" ]]; then
        echo "[ERROR] RABBITMQ_MGMT_PASS 未配置，请检查 .env。" >&2
        issues=$((issues + 1))
    fi

    cert_file="${HEALTHCHECK_TLS_CERT_FILE:-certs/client.pem}"
    key_file="${HEALTHCHECK_TLS_KEY_FILE:-certs/client.key}"
    ca_file="${HEALTHCHECK_TLS_CA_CERT_FILE:-certs/acps-root-ca.pem}"
    for path in "${cert_file}" "${key_file}" "${ca_file}"; do
        if [[ ! -f "${path}" ]]; then
            echo "[WARN]  开发证书缺失：${path}（e2e 需要 mTLS 证书，可执行 just prep certs 按本仓声明重签）" >&2
        fi
    done

    if [[ "${skip_shared_infra_check}" == "1" ]]; then
        echo "[INFO]  跳过共享 infra 检查（SKIP_SHARED_INFRA_DOCTOR=1）。"
    else
        if [[ ! -x {{ dev_infra_script }} ]]; then
            echo "[ERROR] 未找到共享 infra 工具：{{ dev_infra_script }}" >&2
            issues=$((issues + 1))
            infra_ok=0
        elif ! just infra doctor >"${tmpfile}" 2>&1; then
            echo "[ERROR] 共享 infra 工具检查失败。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
            infra_ok=0
        fi

        if [[ "${infra_ok}" -eq 1 ]]; then
            check_service_status redis
            check_service_status rabbitmq
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO]  doctor checks passed for {{ project_name }}"

_bootstrap_common:
    @just infra up redis rabbitmq
    @just infra wait redis rabbitmq
    @just prep env
    @just prep sync
    @just prep hooks
    @just prep certs

package action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    requested_args=()

    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    print_help() {
        echo "package 发布物构建："
        echo "  just package wheel"
        echo "      构建在线运行包（应用 wheel + config/.env.example + requirements-runtime.txt）"
        echo "  just package wheel offline"
        echo "      构建包含 Python 运行时依赖 wheelhouse 的离线包"
        echo "  just package wheel offline --pip-platform manylinux2014_x86_64 --pip-platform manylinux_2_28_x86_64 --pip-implementation cp --pip-abi cp314"
        echo "      为指定目标平台命名发布物，并在依赖 wheel 可用时预下载离线 wheels"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        wheel)
            command=(bash scripts/package-wheel-runtime.sh)

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                if [[ "${requested_args[0]}" == "offline" ]]; then
                    command+=(--offline)
                    requested_args=("${requested_args[@]:1}")
                elif [[ "${requested_args[0]}" == "online" ]]; then
                    requested_args=("${requested_args[@]:1}")
                fi
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                command+=("${requested_args[@]}")
            fi
            "${command[@]}"
            ;;
        *)
            echo "[ERROR] 未知 package action: ${action}" >&2
            exit 2
            ;;
    esac

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{ action }}"

    print_help() {
        echo "prep 维护动作："
        echo "  just prep env           缺失时根据 .env.example 生成 .env"
        echo "  just prep sync          执行 uv sync"
        echo "  just prep hooks         安装/更新 pre-commit 与 commit-msg hooks"
        echo "  just prep certs [reset] 委托共享开发 PKI 按本仓声明签发开发证书；传 reset 时先清理本仓证书再重签"
        echo "  just prep migrate [app|test]  无数据库项目，显式 skip（默认 app）"
    }

    install_git_hooks() {
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "[WARN]  当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            return
        fi

        uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
        echo "[INFO]  已安装或更新 pre-commit / commit-msg hooks。"
    }

    ensure_dev_certs() {
        local mode="${1:-ensure}"
        local dev_pki_script="{{ dev_pki_script }}"
        local cert_file key_file ca_file health_cert_file health_key_file health_ca_file healthcheck_client_aic

        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi

        cert_file="${TLS_CERT_FILE:-certs/server.pem}"
        key_file="${TLS_KEY_FILE:-certs/server.key}"
        ca_file="${TLS_CA_CERT_FILE:-certs/acps-root-ca.pem}"
        health_cert_file="${HEALTHCHECK_TLS_CERT_FILE:-certs/client.pem}"
        health_key_file="${HEALTHCHECK_TLS_KEY_FILE:-certs/client.key}"
        health_ca_file="${HEALTHCHECK_TLS_CA_CERT_FILE:-${ca_file}}"
        healthcheck_client_aic="${HEALTHCHECK_TLS_CLIENT_AIC:-{{ default_healthcheck_client_aic }}}"

        if [[ ! -x "${dev_pki_script}" ]]; then
            echo "[ERROR] 未找到共享开发 PKI 脚本：${dev_pki_script}" >&2
            exit 1
        fi

        if [[ "${mode}" == "reset" ]]; then
            rm -f "${cert_file}" "${key_file}" "${ca_file}" "${health_cert_file}" "${health_key_file}" "${health_ca_file}"
        fi

        bash "${dev_pki_script}" issue-leaf \
            --ca infra \
            --common-name "mq-auth-server" \
            --usage serverAuth \
            --san "DNS:localhost,DNS:mq-auth-server,DNS:host.docker.internal,IP:127.0.0.1" \
            --cert-out "${cert_file}" \
            --key-out "${key_file}" \
            --relative-to "$PWD"

        bash "${dev_pki_script}" issue-leaf \
            --ca agent \
            --common-name "${healthcheck_client_aic}" \
            --usage clientAuth \
            --cert-out "${health_cert_file}" \
            --key-out "${health_key_file}" \
            --relative-to "$PWD"

        bash "${dev_pki_script}" export-ca \
            --ca bundle \
            --bundle-out "${ca_file}" \
            --relative-to "$PWD"

        if [[ "${health_ca_file}" != "${ca_file}" ]]; then
            bash "${dev_pki_script}" export-ca \
                --ca bundle \
                --bundle-out "${health_ca_file}" \
                --relative-to "$PWD"
        fi

        for path in "${cert_file}" "${key_file}" "${ca_file}" "${health_cert_file}" "${health_key_file}"; do
            if [[ ! -f "${path}" ]]; then
                echo "[ERROR] 共享开发 PKI 签发完成后仍缺少证书文件：${path}" >&2
                exit 1
            fi
        done

        echo "[INFO]  development server cert ready: ${cert_file}"
        echo "[INFO]  development server key ready: ${key_file}"
        echo "[INFO]  development client cert ready: ${health_cert_file}"
        echo "[INFO]  development client key ready: ${health_key_file}"
        echo "[INFO]  development ca ready: ${ca_file}"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO]  .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                echo "[INFO]  已根据 .env.example 生成 .env。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            install_git_hooks
            ;;
        certs)
            certs_mode="ensure"
            set -- {{ args }}
            if [[ $# -gt 1 ]]; then
                echo "[ERROR] just prep certs 仅支持一个可选参数：reset。" >&2
                exit 2
            fi
            if [[ $# -eq 1 ]]; then
                if [[ "$1" != "reset" ]]; then
                    echo "[ERROR] just prep certs 仅支持 reset 参数，当前为：$1" >&2
                    exit 2
                fi
                certs_mode="reset"
            fi
            ensure_dev_certs "${certs_mode}"
            ;;
        migrate)
            migrate_target="app"
            set -- {{ args }}
            if [[ $# -gt 1 ]]; then
                echo "[ERROR] just prep migrate 只接受一个可选目标参数：app 或 test。" >&2
                exit 2
            fi
            if [[ $# -eq 1 ]]; then
                if [[ "$1" != "app" && "$1" != "test" ]]; then
                    echo "[ERROR] just prep migrate 仅支持 app 或 test，当前为：$1" >&2
                    exit 2
                fi
                migrate_target="$1"
            fi
            echo "[INFO]  {{ project_name }} 无数据库迁移，跳过 migrate ${migrate_target}。"
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

app action='start' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{ action }}"
    args_string="{{ args }}"
    pid_file="{{ app_pid_file }}"
    log_file="{{ app_log_file }}"
    health_url="{{ group_health_url }}"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    ensure_log_dir() {
        mkdir -p "$(dirname "${pid_file}")"
    }

    load_dotenv() {
        set -a
        source .env
        set +a
    }

    read_pid() {
        if [[ -f "${pid_file}" ]]; then
            tr -d '[:space:]' < "${pid_file}"
        fi
    }

    is_running() {
        local pid="$1"
        [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
    }

    cleanup_stale_pid() {
        local pid=""
        pid="$(read_pid || true)"
        if [[ -n "${pid}" ]] && ! is_running "${pid}"; then
            rm -f "${pid_file}"
            echo "[WARN]  检测到 stale pid ${pid}，已移除 ${pid_file}。"
        fi
    }

    wait_for_health() {
        local pid="$1"
        local attempt=""
        for attempt in {1..30}; do
            if uv run python -m app.core.health_probe --url "${health_url}" >/dev/null 2>&1; then
                return 0
            fi

            if ! is_running "${pid}"; then
                return 1
            fi

            sleep 1
        done

        return 1
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate app
            ;;
        start|"")
            just doctor
            load_dotenv

            mode="${requested_args[0]:-bg}"
            case "${mode}" in
                bg)
                    ensure_log_dir
                    cleanup_stale_pid
                    pid="$(read_pid || true)"
                    if [[ -n "${pid}" ]] && is_running "${pid}"; then
                        echo "[INFO]  {{ project_name }} 已在运行（pid=${pid}）。"
                        exit 0
                    fi

                    nohup uv run mq-auth-server >> "${log_file}" 2>&1 &
                    pid="$!"
                    echo "${pid}" > "${pid_file}"

                    if ! wait_for_health "${pid}"; then
                        echo "[ERROR] {{ project_name }} 启动后未通过健康检查，查看日志：${log_file}" >&2
                        kill "${pid}" 2>/dev/null || true
                        rm -f "${pid_file}"
                        exit 1
                    fi

                    echo "[INFO]  {{ project_name }} 已后台启动（pid=${pid}，log=${log_file}）。"
                    ;;
                fg)
                    exec uv run mq-auth-server
                    ;;
                *)
                    echo "[ERROR] 未知 app start 模式：${mode}（仅支持 bg / fg）。" >&2
                    exit 2
                    ;;
            esac
            ;;
        stop)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if [[ -z "${pid}" ]]; then
                echo "[INFO]  {{ project_name }} 当前未运行。"
                exit 0
            fi

            if ! is_running "${pid}"; then
                rm -f "${pid_file}"
                echo "[INFO]  {{ project_name }} 已停止。"
                exit 0
            fi

            kill "${pid}" 2>/dev/null || true
            for _ in {1..20}; do
                if ! is_running "${pid}"; then
                    break
                fi
                sleep 1
            done

            if is_running "${pid}"; then
                echo "[ERROR] 无法在超时时间内停止 {{ project_name }}（pid=${pid}）。" >&2
                exit 1
            fi

            rm -f "${pid_file}"
            echo "[INFO]  {{ project_name }} 已停止。"
            ;;
        status)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if [[ -n "${pid}" ]] && is_running "${pid}"; then
                echo "[INFO]  {{ project_name }} 正在运行（pid=${pid}，log=${log_file}）。"
            else
                echo "[INFO]  {{ project_name }} 当前未运行。"
            fi
            ;;
        logs)
            if [[ ! -f "${log_file}" ]]; then
                echo "[WARN]  尚未生成日志文件：${log_file}"
                exit 0
            fi

            if [[ "${requested_args[0]:-}" == "follow" ]]; then
                exec tail -n 200 -f "${log_file}"
            fi

            tail -n 200 "${log_file}"
            ;;
        restart)
            if [[ -n "${requested_args[0]:-}" ]] && [[ "${requested_args[0]}" != "bg" ]]; then
                echo "[ERROR] app restart 只管理后台实例；如需前台运行，请直接执行 just app start fg。" >&2
                exit 2
            fi
            just app stop
            just app start
            ;;
        *)
            echo "[ERROR] 未知 app action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{ action }}"
    args_string="{{ args }}"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    run_requested_tests() {
        local default_path="$1"

        if [[ "${#requested_args[@]}" -eq 0 ]]; then
            uv run pytest "${default_path}"
            return
        fi

        if [[ "${requested_args[0]}" == -* ]]; then
            uv run pytest "${default_path}" "${requested_args[@]}"
            return
        fi

        uv run pytest "${requested_args[@]}"
    }

    run_test_doctor() {
        local mode="${1:-integration}"

        case "${mode}" in
            integration)
                SKIP_DOTENV_DOCTOR=1 \
                SKIP_RABBITMQ_MGMT_PASS_DOCTOR=1 \
                SKIP_SHARED_INFRA_DOCTOR=1 \
                just doctor
                ;;
            e2e)
                SKIP_DOTENV_DOCTOR=1 \
                SKIP_RABBITMQ_MGMT_PASS_DOCTOR=1 \
                just doctor
                ;;
            *)
                echo "[ERROR] 未知 test doctor mode: ${mode}" >&2
                exit 2
                ;;
        esac
    }

    run_venv_python() {
        uv run --no-sync python "$@"
    }

    find_free_port() {
        run_venv_python -c 'import socket; sock = socket.socket(); sock.bind(("127.0.0.1", 0)); print(sock.getsockname()[1]); sock.close()'
    }

    validate_test_e2e_base_url() {
        local base_url="$1"

        if ! run_venv_python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); host = parts.hostname or ""; ok = parts.scheme in {"https"} and host in {"127.0.0.1", "localhost"} and parts.port is not None and parts.path in {"", "/"}; raise SystemExit(0 if ok else 1)' "${base_url}"; then
            echo "[ERROR] e2e 临时服务地址必须为本地 HTTPS URL，例如：https://127.0.0.1:19123。" >&2
            exit 1
        fi
    }

    stop_test_server() {
        if [[ -n "${group_server_pid:-}" ]] && kill -0 "${group_server_pid}" 2>/dev/null; then
            kill "${group_server_pid}" 2>/dev/null || true
            wait "${group_server_pid}" 2>/dev/null || true
            echo "[INFO]  已停止临时 Group API 实例。"
        fi

        if [[ -n "${auth_server_pid:-}" ]] && kill -0 "${auth_server_pid}" 2>/dev/null; then
            kill "${auth_server_pid}" 2>/dev/null || true
            wait "${auth_server_pid}" 2>/dev/null || true
            echo "[INFO]  已停止临时 Auth API 实例。"
        fi

        if [[ -n "${test_server_log:-}" ]] && [[ -f "${test_server_log}" ]]; then
            echo "[INFO]  e2e 临时实例日志保留于：${test_server_log}"
        fi
    }

    wait_for_test_server() {
        local group_url="$1"
        local auth_url="$2"
        local attempt

        probe_cert_file="${E2E_TLS_CERT_FILE:-certs/client.pem}"
        probe_key_file="${E2E_TLS_KEY_FILE:-certs/client.key}"
        probe_ca_file="${E2E_TLS_CA_CERT_FILE:-certs/acps-root-ca.pem}"

        for attempt in {1..45}; do
            if APP_ENV=development \
                HEALTHCHECK_TLS_CERT_FILE="${probe_cert_file}" \
                HEALTHCHECK_TLS_KEY_FILE="${probe_key_file}" \
                HEALTHCHECK_TLS_CA_CERT_FILE="${probe_ca_file}" \
                uv run python -m app.core.health_probe --url "${group_url}/health" >/dev/null 2>&1 \
                && APP_ENV=development \
                HEALTHCHECK_TLS_CERT_FILE="${probe_cert_file}" \
                HEALTHCHECK_TLS_KEY_FILE="${probe_key_file}" \
                HEALTHCHECK_TLS_CA_CERT_FILE="${probe_ca_file}" \
                uv run python -m app.core.health_probe --url "${auth_url}/health" >/dev/null 2>&1; then
                return 0
            fi

            if [[ -n "${group_server_pid:-}" ]] && ! kill -0 "${group_server_pid}" 2>/dev/null; then
                echo "[ERROR] 临时 Group API 实例启动失败。" >&2
                cat "${test_server_log}" >&2
                return 1
            fi

            if [[ -n "${auth_server_pid:-}" ]] && ! kill -0 "${auth_server_pid}" 2>/dev/null; then
                echo "[ERROR] 临时 Auth API 实例启动失败。" >&2
                cat "${test_server_log}" >&2
                return 1
            fi

            sleep 1
        done

        echo "[ERROR] 等待临时 e2e 实例就绪超时。" >&2
        cat "${test_server_log}" >&2
        return 1
    }

    start_test_server() {
        local group_port="$1"
        local auth_port="$2"

        load_dotenv
        test_server_log="$(mktemp "${TMPDIR:-/tmp}/mq-auth-server-e2e.XXXXXX")"

        APP_ENV=development \
        RABBITMQ_MGMT_PASS="${RABBITMQ_MGMT_PASS:-devpass}" \
        REDIS_URL="${REDIS_URL:-redis://localhost:6379/0}" \
        RABBITMQ_MGMT_URL="${RABBITMQ_MGMT_URL:-http://localhost:15672}" \
        uv run python -c 'import sys; from app.main import GROUP_LISTENER, _serve_listener; _serve_listener(GROUP_LISTENER, int(sys.argv[1]))' "${group_port}" >"${test_server_log}" 2>&1 &
        group_server_pid="$!"

        APP_ENV=development \
        RABBITMQ_MGMT_PASS="${RABBITMQ_MGMT_PASS:-devpass}" \
        REDIS_URL="${REDIS_URL:-redis://localhost:6379/0}" \
        RABBITMQ_MGMT_URL="${RABBITMQ_MGMT_URL:-http://localhost:15672}" \
        uv run python -c 'import sys; from app.main import AUTH_LISTENER, _serve_listener; _serve_listener(AUTH_LISTENER, int(sys.argv[1]))' "${auth_port}" >>"${test_server_log}" 2>&1 &
        auth_server_pid="$!"
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate test
            ;;
        unit)
            run_requested_tests tests/unit/
            ;;
        coverage)
            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                uv run pytest tests/unit/ "${requested_args[@]}" --cov=app --cov-report=term-missing --cov-fail-under=70
            else
                uv run pytest tests/unit/ --cov=app --cov-report=term-missing --cov-fail-under=70
            fi
            ;;
        integration)
            run_test_doctor integration
            run_requested_tests tests/integration/
            ;;
        e2e)
            run_test_doctor e2e
            just prep certs
            group_port="$(find_free_port)"
            auth_port="$(find_free_port)"
            group_api_url="https://localhost:${group_port}"
            auth_api_url="https://localhost:${auth_port}"
            tls_cert_file="${E2E_TLS_CERT_FILE:-certs/client.pem}"
            tls_key_file="${E2E_TLS_KEY_FILE:-certs/client.key}"
            tls_ca_cert_file="${E2E_TLS_CA_CERT_FILE:-certs/acps-root-ca.pem}"
            derived_leader_aic="$(openssl x509 -in "${tls_cert_file}" -noout -subject -nameopt RFC2253 | sed -E 's/^subject=//; s/.*CN=([^,]+).*/\1/')"
            if [[ -z "${derived_leader_aic}" ]]; then
                echo "[ERROR] 无法从测试客户端证书解析 Leader AIC: ${tls_cert_file}" >&2
                exit 1
            fi
            validate_test_e2e_base_url "${group_api_url}"
            validate_test_e2e_base_url "${auth_api_url}"

            trap stop_test_server EXIT
            start_test_server "${group_port}" "${auth_port}"
            wait_for_test_server "${group_api_url}" "${auth_api_url}"

            GROUP_API_URL="${group_api_url}" \
            AUTH_API_URL="${auth_api_url}" \
            TLS_CERT_FILE="${tls_cert_file}" \
            TLS_KEY_FILE="${tls_key_file}" \
            TLS_CA_CERT_FILE="${tls_ca_cert_file}" \
            E2E_TEST_AIC="${E2E_TEST_AIC:-${derived_leader_aic}}" \
            E2E_LEADER_AIC="${E2E_LEADER_AIC:-${derived_leader_aic}}" \
            E2E_MEMBER_AIC="${E2E_MEMBER_AIC:-1.2.156.3088.1.1.9ABC.123456.654321.2XYZ}" \
            run_requested_tests tests/e2e/
            ;;
        all|"")
            just test unit
            just test integration
            just test e2e
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all':
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{ action }}"

    case "${action}" in
        lint)
            uv run ruff format --check .
            uv run ruff check .
            ;;
        fmt)
            uv run ruff format .
            ;;
        type)
            just qa type-app
            ;;
        type-app)
            uv run mypy --config-file pyproject.toml app
            ;;
        type-tests)
            uv run mypy --config-file pyproject.toml tests
            ;;
        security)
            uv run bandit -c pyproject.toml -r app
            ;;
        audit)
            uv run pip-audit
            ;;
        full)
            just qa lint
            just qa type-app
            just qa type-tests
            just qa security
            ;;
        fix)
            uv run ruff format .
            uv run ruff check . --fix
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        all|"")
            just qa fix
            just qa precommit
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac
