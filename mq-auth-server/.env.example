# mq-auth-server 环境变量配置
# 复制为 .env 后填写实际值
# 非敏感配置项已迁移至 config/*.toml，此处仅保留敏感/部署相关变量

# 环境选择（决定加载哪个 TOML 配置文件：development / testing / production）
APP_ENV=development

# RabbitMQ Management API 凭据（共享 dev-infra 默认使用 admin / devpass）
RABBITMQ_MGMT_PASS=devpass

# RabbitMQ Management API 地址（共享 dev-infra）
RABBITMQ_MGMT_URL=http://localhost:15672

# Redis 连接（共享 dev-infra）
REDIS_URL=redis://localhost:6379/0
# Redis TLS CA 证书路径（不使用 TLS 时置空）
REDIS_TLS_CA_CERT=

# TLS 证书（mTLS 双向认证，本地开发默认写入项目内 certs/）
TLS_CERT_FILE=certs/server.pem
TLS_KEY_FILE=certs/server.key
TLS_CA_CERT_FILE=certs/acps-root-ca.pem

# 健康检查 / 冒烟测试客户端证书
# development 默认复用自动生成的 Leader 证书；testing / production 请按需覆盖
HEALTHCHECK_TLS_CERT_FILE=certs/client.pem
HEALTHCHECK_TLS_KEY_FILE=certs/client.key
HEALTHCHECK_TLS_CA_CERT_FILE=certs/acps-root-ca.pem
