# 运行环境
# 非敏感运行时配置默认来自 config/default.toml + config/{APP_ENV}.toml。
# .env 只保留敏感信息，以及少量需要按机器/部署覆盖的配置。
APP_ENV=development

# 数据库连接（shared dev-infra 默认值）
DATABASE_URL=postgresql+asyncpg://discovery:discovery@localhost:5432/agent_discovery
TEST_DATABASE_URL=postgresql+asyncpg://discovery:discovery@localhost:5432/agent_discovery_test
# 可选：bootstrap/migrate 用于自动确保 pgvector 扩展的管理员连接；未设置时回退到 shared dev-infra 默认 postgres 账号
# DATABASE_ADMIN_URL=postgresql://postgres:devpass@localhost:5432/postgres
# TEST_DATABASE_ADMIN_URL=postgresql://postgres:devpass@localhost:5432/postgres

# DSP WebHook 密钥（敏感）
DSP_WEBHOOK_SECRET=

# CPU 模式：Embedding LLM 配置（敏感）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Discovery LLM 配置（敏感）
DISCOVERY_LLM_API_KEY=
# 以下示例使用阿里云百炼 OpenAI 兼容接口的北京地域地址；如使用其它地域请替换
DISCOVERY_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DISCOVERY_LLM_MODEL_NAME=qwen-plus
