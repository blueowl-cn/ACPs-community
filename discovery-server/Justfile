set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

project_name := "discovery-server"
dev_infra_script := "../acps-infra/dev-infra/dev-infra.sh"
app_pid_file := "logs/discovery-server.pid"
app_log_file := "logs/discovery-server.log"
legacy_pid_file := "logs/service.pid"
test_e2e_log_file := "logs/discovery-server-e2e.log"
default_test_database_url := "postgresql+asyncpg://discovery:discovery@localhost:5432/agent_discovery_test"

default:
    @just help

help:
        @echo "discovery-server Just 命令"
        @echo ""
        @echo "用法："
        @echo "  just app [action] [args...]"
        @echo "  just test [action] [args...]"
        @echo "  just qa [action] [args...]"
        @echo "  just package [action] [args...]"
        @echo "  just infra [action] [args...]"
        @echo "  just doctor"
        @echo "  just prep [action] [args...]"
        @echo ""
        @echo "app：本地应用生命周期"
        @echo "  bootstrap        建立开发环境（infra up + prep env + prep sync + prep hooks + prep migrate app）"
        @echo "  start            后台启动服务（默认动作），日志写入 logs/discovery-server.log"
        @echo "  start bg         显式后台启动服务"
        @echo "  start fg         前台启动服务，占用当前 console"
        @echo "  stop             停止后台实例"
        @echo "  status           查看后台实例状态"
        @echo "  logs             查看后台日志末尾 200 行"
        @echo "  logs follow      持续跟随后台日志"
        @echo "  restart          重启受管后台实例"
        @echo ""
        @echo "test：测试入口"
        @echo "  bootstrap        建立测试环境（infra up + prep env + prep sync + prep hooks + prep migrate test）"
        @echo "  unit             运行单元测试；无测试文件时返回成功"
        @echo "  integration      执行只读预检后运行集成测试，并自动准备测试样本数据"
        @echo "  e2e              执行只读预检后运行端到端测试，并自动准备测试样本数据"
        @echo "  coverage         运行带覆盖率报告的 pytest，并自动准备测试样本数据"
        @echo "  all              依次执行 unit -> integration -> e2e（默认动作）"
        @echo ""
        @echo "qa：代码质量入口"
        @echo "  fmt              执行 ruff format ."
        @echo "  fix              执行 format + ruff check --fix"
        @echo "  lint             执行只读 ruff check ."
        @echo "  type-app         对 app/ 与 main.py 执行 mypy"
        @echo "  type-tests       对 tests/ 执行 mypy"
        @echo "  type-strict-coverage  检查 mypy strict 覆盖范围是否与仓库同步"
        @echo "  security         对 app/、scripts/、main.py 执行 Bandit"
        @echo "  audit            执行 pip-audit 依赖漏洞检查"
        @echo "  full             执行 lint -> type-app -> type-tests -> type-strict-coverage -> security"
        @echo "  precommit        执行 pre-commit run --all-files"
        @echo "  all              依次执行 fix -> precommit"
        @echo ""
        @echo "package：原生 wheel 运行包构建"
        @echo "  wheel                                      构建在线运行包（应用 wheel + acps-sdk wheel + config/alembic/.env.example）"
        @echo "  wheel offline                              构建包含 Python 运行时依赖 wheelhouse 的离线包"
        @echo "  wheel offline --pip-platform <tag> ...     按指定平台命名发布物并下载离线 wheels"
        @echo "  透传选项：--python-version 3.14 --pip-platform <tag> --pip-implementation cp --pip-abi cp314"
        @echo ""
        @echo "infra：共享依赖管理"
        @echo "  status [service...] [--format=tsv]   查看共享依赖状态"
        @echo "  up [service...]                      启动共享依赖，默认 postgres"
        @echo "  down                                 停止共享依赖"
        @echo "  wait [service...]                    等待共享依赖就绪"
        @echo "  logs [service...] [--follow]         查看共享依赖日志"
        @echo "  reset [service...] [--volumes --yes] 修复性重建共享依赖"
        @echo "  doctor                               检查共享 infra 环境"
        @echo ""
        @echo "doctor：只读环境检查"
        @echo "  检查 uv / .venv Python / just / .env / uv sync 状态 / dev-infra / PostgreSQL 健康状态"
        @echo ""
        @echo "prep：维护与局部修复动作"
        @echo "  env      缺失时根据 .env.example 生成 .env"
        @echo "  sync     执行 uv sync"
        @echo "  hooks    安装/更新 pre-commit 与 commit-msg hooks"
        @echo "  migrate [app|test]  对开发/测试数据库执行 alembic upgrade head"
        @echo "  seed [app|test]     向指定数据库导入 demo ACS 样本并建立本地技能索引（默认 app）"
        @echo "  reseed [app|test]   清空指定数据库中的 Agent/Skill 后重新导入 demo ACS 样本（默认 app）"
        @echo "  sync-embedding-dimension [app|test] [args...]  同步 skills.embedding 维度到 EMBEDDING_DIM（默认 app）"

infra action='status' *args:
    @{{dev_infra_script}} {{action}} {{args}}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0
    infra_ok=1

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    elif ! uv run --no-sync python -c 'import sys; raise SystemExit(0 if sys.version_info[:2] == (3, 14) else 1)' >"${tmpfile}" 2>&1; then
        echo "[ERROR] .venv Python 版本不满足 pyproject.toml 要求（需要 >=3.14,<3.15）。请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -f .env ]]; then
        echo "[ERROR] 未找到 .env，请先执行 just prep env。" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -x {{dev_infra_script}} ]]; then
        echo "[ERROR] 未找到共享 infra 工具：{{dev_infra_script}}" >&2
        issues=$((issues + 1))
        infra_ok=0
    elif ! just infra doctor >"${tmpfile}" 2>&1; then
        echo "[ERROR] 共享 infra 工具检查失败。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
        infra_ok=0
    fi

    if [[ "${infra_ok}" -eq 1 ]]; then
        if ! status_output="$(just infra status postgres --format=tsv 2>"${tmpfile}")"; then
            echo "[ERROR] 无法读取共享 PostgreSQL 状态。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
        elif [[ -z "${status_output}" ]]; then
            echo "[ERROR] 共享 PostgreSQL 状态输出为空。" >&2
            issues=$((issues + 1))
        else
            IFS=$'\t' read -r service _mode state health _ports <<<"${status_output%%$'\n'*}"

            if [[ "${service}" != "postgres" ]]; then
                echo "[ERROR] 共享 PostgreSQL 状态输出格式异常：${status_output}" >&2
                issues=$((issues + 1))
            else
                if [[ "${state}" != "running" ]]; then
                    echo "[ERROR] 共享 PostgreSQL 未运行（state=${state}）。请先执行 just infra up postgres。" >&2
                    issues=$((issues + 1))
                fi

                if [[ "${health}" != "healthy" ]]; then
                    echo "[ERROR] 共享 PostgreSQL 未健康（health=${health}）。" >&2
                    issues=$((issues + 1))
                fi
            fi
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO] doctor checks passed for {{project_name}}"

_bootstrap_common:
    @just infra up postgres
    @just prep env
    @just prep sync
    @just prep hooks

package action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    requested_args=()

    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    print_help() {
        echo "package 发布物构建："
        echo "  just package wheel"
        echo "      构建在线运行包（应用 wheel + acps-sdk wheel + config/alembic/.env.example）"
        echo "  just package wheel offline"
        echo "      构建包含 Python 运行时依赖 wheelhouse 的离线包"
        echo "  just package wheel offline --pip-platform manylinux2014_x86_64 --pip-platform manylinux_2_28_x86_64 --pip-implementation cp --pip-abi cp314"
        echo "      为指定目标平台命名发布物，并在依赖 wheel 可用时预下载离线 wheels"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        wheel)
            command=(bash scripts/package-wheel-runtime.sh)

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                if [[ "${requested_args[0]}" == "offline" ]]; then
                    command+=(--offline)
                    requested_args=("${requested_args[@]:1}")
                elif [[ "${requested_args[0]}" == "online" ]]; then
                    requested_args=("${requested_args[@]:1}")
                fi
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                command+=("${requested_args[@]}")
            fi
            "${command[@]}"
            ;;
        *)
            echo "[ERROR] 未知 package action: ${action}" >&2
            exit 2
            ;;
    esac

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    resolve_test_database_url() {
        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        if [[ -f .env ]]; then
            dot_env_test_database_url="$(uv run python -c 'from pathlib import Path; from dotenv import dotenv_values; env_path = Path(".env"); print((dotenv_values(env_path).get("TEST_DATABASE_URL") or "").strip())' 2>/dev/null || true)"
            if [[ -n "${dot_env_test_database_url}" ]]; then
                printf '%s\n' "${dot_env_test_database_url}"
                return
            fi
        fi

        printf '%s\n' "{{default_test_database_url}}"
    }

    case "${action}" in
        help|"")
            echo "prep 维护动作："
            echo "  just prep env           缺失时根据 .env.example 生成 .env"
            echo "  just prep sync          执行 uv sync"
            echo "  just prep hooks         安装/更新 pre-commit 与 commit-msg hooks"
            echo "  just prep migrate [app|test]  对开发/测试数据库执行 alembic upgrade head（默认 app）"
            echo "  just prep seed [app|test]     向指定数据库导入 demo ACS 样本并建立本地技能索引（默认 app）"
            echo "  just prep reseed [app|test]   清空指定数据库中的 Agent/Skill 后重新导入 demo ACS 样本（默认 app）"
            echo "  just prep sync-embedding-dimension [app|test] [args...]  同步 skills.embedding 维度到 EMBEDDING_DIM（默认 app）"
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO] .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                echo "[INFO] 已根据 .env.example 生成 .env。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            if git rev-parse --git-dir >/dev/null 2>&1; then
                uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
                echo "[INFO] 已安装或更新 pre-commit / commit-msg hooks。"
            else
                echo "[WARN] 当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            fi
            ;;
        migrate)
            migrate_target="app"
            set -- {{args}}
            if [[ $# -gt 1 ]]; then
                echo "[ERROR] just prep migrate 只接受一个可选目标参数：app 或 test。" >&2
                exit 2
            fi
            if [[ $# -eq 1 ]]; then
                if [[ "$1" != "app" && "$1" != "test" ]]; then
                    echo "[ERROR] just prep migrate 仅支持 app 或 test，当前为：$1" >&2
                    exit 2
                fi
                migrate_target="$1"
            fi

            if [[ "${migrate_target}" == "app" ]]; then
                uv run python scripts/ensure_vector_extension.py --database-url-env DATABASE_URL --admin-url-env DATABASE_ADMIN_URL
                uv run alembic upgrade head
            else
                test_database_url="$(resolve_test_database_url)"
                TEST_DATABASE_URL="${test_database_url}" uv run python scripts/ensure_test_database.py
                APP_ENV=testing DATABASE_URL="${test_database_url}" TEST_DATABASE_URL="${test_database_url}" uv run alembic upgrade head
            fi
            ;;
        seed)
            set -- {{args}}
            seed_target="app"
            if [[ $# -gt 0 ]] && [[ "$1" == "app" || "$1" == "test" ]]; then
                seed_target="$1"
                shift
            fi
            seed_is_dry_run=0
            for seed_arg in "$@"; do
                if [[ "${seed_arg}" == "--dry-run" ]]; then
                    seed_is_dry_run=1
                    break
                fi
            done
            if [[ "${seed_target}" == "test" && "${seed_is_dry_run}" -eq 0 ]]; then
                test_database_url="$(resolve_test_database_url)"
                TEST_DATABASE_URL="${test_database_url}" uv run python scripts/check_test_database_ready.py
            fi
            uv run python scripts/seed.py "${seed_target}" "$@"
            ;;
        reseed)
            set -- {{args}}
            seed_target="app"
            if [[ $# -gt 0 ]] && [[ "$1" == "app" || "$1" == "test" ]]; then
                seed_target="$1"
                shift
            fi
            seed_is_dry_run=0
            for seed_arg in "$@"; do
                if [[ "${seed_arg}" == "--dry-run" ]]; then
                    seed_is_dry_run=1
                    break
                fi
            done
            if [[ "${seed_target}" == "test" && "${seed_is_dry_run}" -eq 0 ]]; then
                test_database_url="$(resolve_test_database_url)"
                TEST_DATABASE_URL="${test_database_url}" uv run python scripts/check_test_database_ready.py
            fi
            uv run python scripts/seed.py "${seed_target}" --reset "$@"
            ;;
        sync-embedding-dimension)
            set -- {{args}}
            sync_target="app"
            if [[ $# -gt 0 ]] && [[ "$1" == "app" || "$1" == "test" ]]; then
                sync_target="$1"
                shift
            fi

            if [[ "${sync_target}" == "app" ]]; then
                uv run python scripts/maintenance/sync_embedding_dimension.py "$@"
            else
                test_database_url="$(resolve_test_database_url)"
                TEST_DATABASE_URL="${test_database_url}" uv run python scripts/check_test_database_ready.py
                APP_ENV=testing DATABASE_URL="${test_database_url}" TEST_DATABASE_URL="${test_database_url}" \
                    uv run python scripts/maintenance/sync_embedding_dimension.py "$@"
            fi
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

app action='start' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    pid_file="{{app_pid_file}}"
    log_file="{{app_log_file}}"
    legacy_pid_file="{{legacy_pid_file}}"

    ensure_logs_dir() {
        mkdir -p logs
    }

    read_live_pid() {
        local candidate="$1"

        if [[ ! -f "${candidate}" ]]; then
            return 1
        fi

        local pid
        pid="$(tr -d '[:space:]' <"${candidate}")"
        if [[ -z "${pid}" ]]; then
            rm -f "${candidate}"
            return 1
        fi

        if kill -0 "${pid}" 2>/dev/null; then
            printf '%s\n' "${pid}"
            return 0
        fi

        rm -f "${candidate}"
        return 1
    }

    start_bg() {
        ensure_logs_dir

        if pid="$(read_live_pid "${pid_file}")"; then
            echo "[INFO] discovery-server 已在运行（PID=${pid}）。"
            exit 0
        fi

        if legacy_pid="$(read_live_pid "${legacy_pid_file}")"; then
            echo "[INFO] 检测到 legacy 启动实例仍在运行（PID=${legacy_pid}）。"
            exit 0
        fi

        nohup env PYTHONPATH="$PWD" uv run python -m app.main >>"${log_file}" 2>&1 &
        app_pid=$!
        echo "${app_pid}" >"${pid_file}"

        sleep 3

        if ! kill -0 "${app_pid}" 2>/dev/null; then
            rm -f "${pid_file}"
            echo "[ERROR] discovery-server 启动失败，请检查 ${log_file}。" >&2
            exit 1
        fi

        echo "[INFO] discovery-server 已启动（PID=${app_pid}）。"
        echo "[INFO] 日志文件：${log_file}"
    }

    stop_pid() {
        local target_pid="$1"
        kill "${target_pid}" 2>/dev/null || true
        sleep 2
        if kill -0 "${target_pid}" 2>/dev/null; then
            kill -9 "${target_pid}" 2>/dev/null || true
            sleep 1
        fi
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate app
            ;;
        start|"")
            if [[ -z "${args_string}" || "${args_string}" == "bg" ]]; then
                just doctor
                start_bg
            elif [[ "${args_string}" == "fg" ]]; then
                just doctor
                ensure_logs_dir
                exec env PYTHONPATH="$PWD" uv run python -m app.main
            else
                echo "[ERROR] 未知 app start 参数：${args_string}" >&2
                exit 2
            fi
            ;;
        stop)
            if pid="$(read_live_pid "${pid_file}")"; then
                stop_pid "${pid}"
                rm -f "${pid_file}"
                echo "[INFO] 已停止受管实例（PID=${pid}）。"
            elif legacy_pid="$(read_live_pid "${legacy_pid_file}")"; then
                stop_pid "${legacy_pid}"
                rm -f "${legacy_pid_file}"
                echo "[INFO] 已停止 legacy 实例（PID=${legacy_pid}）。"
            else
                echo "[INFO] discovery-server 当前未运行。"
            fi
            ;;
        status)
            if pid="$(read_live_pid "${pid_file}")"; then
                echo "[INFO] discovery-server 正在运行（PID=${pid}，受管实例）。"
            elif legacy_pid="$(read_live_pid "${legacy_pid_file}")"; then
                echo "[INFO] discovery-server 正在运行（PID=${legacy_pid}，legacy 实例）。"
            else
                echo "[INFO] discovery-server 未运行。"
            fi
            ;;
        logs)
            ensure_logs_dir
            if [[ "${args_string}" == "follow" ]]; then
                touch "${log_file}"
                exec tail -n 200 -f "${log_file}"
            fi
            touch "${log_file}"
            tail -n 200 "${log_file}"
            ;;
        restart)
            just app stop
            just app start bg
            ;;
        *)
            echo "[ERROR] 未知 app action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    extra_args="{{args}}"
    test_database_url=""

    resolve_test_database_url() {
        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        if [[ -f .env ]]; then
            dot_env_test_database_url="$(uv run python -c 'from pathlib import Path; from dotenv import dotenv_values; env_path = Path(".env"); print((dotenv_values(env_path).get("TEST_DATABASE_URL") or "").strip())' 2>/dev/null || true)"
            if [[ -n "${dot_env_test_database_url}" ]]; then
                printf '%s\n' "${dot_env_test_database_url}"
                return
            fi
        fi

        printf '%s\n' "{{default_test_database_url}}"
    }

    resolve_test_mode() {
        local explicit_mode="${DISCOVERY_TEST_MODE:-${DISCOVERY_MODE:-cpu}}"
        explicit_mode="$(printf '%s' "${explicit_mode}" | tr '[:upper:]' '[:lower:]')"
        if [[ -z "${explicit_mode}" ]]; then
            explicit_mode="cpu"
        fi
        printf '%s\n' "${explicit_mode}"
    }

    resolve_e2e_mode() {
        local explicit_mode="${DISCOVERY_E2E_MODE:-${DISCOVERY_MODE:-cpu}}"
        explicit_mode="$(printf '%s' "${explicit_mode}" | tr '[:upper:]' '[:lower:]')"
        if [[ -z "${explicit_mode}" ]]; then
            explicit_mode="cpu"
        fi
        printf '%s\n' "${explicit_mode}"
    }

    resolve_local_env_value() {
        local env_key="$1"

        if [[ ! -f .env ]]; then
            return 0
        fi

        uv run python -c 'from pathlib import Path; from dotenv import dotenv_values; import sys; env_path = Path(".env"); env_key = sys.argv[1]; print((dotenv_values(env_path).get(env_key) or "").strip())' "${env_key}" 2>/dev/null || true
    }

    has_tests_in() {
        local target_dir="$1"

        if [[ ! -d "${target_dir}" ]]; then
            return 1
        fi

        find "${target_dir}" -type f \( -name 'test_*.py' -o -name '*_test.py' \) -print -quit | grep -q .
    }

    ensure_logs_dir() {
        mkdir -p logs
    }

    read_live_pid() {
        local candidate="$1"

        if [[ ! -f "${candidate}" ]]; then
            return 1
        fi

        local pid
        pid="$(tr -d '[:space:]' <"${candidate}")"
        if [[ -z "${pid}" ]]; then
            rm -f "${candidate}"
            return 1
        fi

        if kill -0 "${pid}" 2>/dev/null; then
            printf '%s\n' "${pid}"
            return 0
        fi

        rm -f "${candidate}"
        return 1
    }

    stop_pid() {
        local target_pid="$1"
        kill "${target_pid}" 2>/dev/null || true
        sleep 2
        if kill -0 "${target_pid}" 2>/dev/null; then
            kill -9 "${target_pid}" 2>/dev/null || true
            sleep 1
        fi
    }

    ensure_test_ready() {
        test_database_url="$(resolve_test_database_url)"

        TEST_DATABASE_URL="${test_database_url}" uv run python scripts/check_test_database_ready.py
    }

    validate_test_e2e_base_url() {
        local base_url="$1"

        if ! uv run --no-sync python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); host = parts.hostname or ""; ok = parts.scheme in {"http", "https"} and host in {"127.0.0.1", "localhost"} and parts.port is not None and parts.path in {"", "/"}; raise SystemExit(0 if ok else 1)' "${base_url}"; then
            echo "[ERROR] TEST_E2E_BASE_URL 必须是指向本地临时测试实例的完整 URL，例如：http://127.0.0.1:19123。" >&2
            exit 1
        fi
    }

    find_free_port() {
        uv run --no-sync python -c 'import socket; sock = socket.socket(); sock.bind(("127.0.0.1", 0)); print(sock.getsockname()[1]); sock.close()'
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate test
            ;;
        unit)
            if ! has_tests_in tests/unit; then
                echo "[INFO] 当前无测试文件，跳过 unit。"
                exit 0
            fi
            uv run pytest tests/unit {{args}}
            ;;
        integration)
            if ! has_tests_in tests/integration; then
                echo "[INFO] 当前无测试文件，跳过 integration。"
                exit 0
            fi

            if [[ -z "${DISCOVERY_TEST_MODE:-}" ]]; then
                echo "[INFO] 未显式指定 discovery mode，integration 将依次运行 CPU 和 GPU 两种模式。"
                DISCOVERY_TEST_MODE=cpu just test integration {{args}}
                DISCOVERY_TEST_MODE=gpu just test integration {{args}}
                exit 0
            fi

            ensure_test_ready
            test_mode="$(resolve_test_mode)"
            TEST_DATABASE_URL="${test_database_url}" DISCOVERY_TEST_MODE="${test_mode}" DISCOVERY_MODE="${test_mode}" uv run pytest tests/integration {{args}}
            ;;
        coverage)
            if ! has_tests_in tests; then
                echo "[INFO] 当前无测试文件，跳过 coverage。"
                exit 0
            fi
            ensure_test_ready
            test_mode="$(resolve_test_mode)"
            e2e_mode="$(resolve_e2e_mode)"
            TEST_DATABASE_URL="${test_database_url}" DISCOVERY_TEST_MODE="${test_mode}" DISCOVERY_E2E_MODE="${e2e_mode}" DISCOVERY_MODE="${test_mode}" \
                uv run pytest --cov=app --cov-report=term-missing --cov-report=html tests {{args}}
            ;;
        e2e)
            if ! has_tests_in tests/e2e; then
                echo "[INFO] 当前无 e2e 测试文件，跳过 e2e。"
                exit 0
            fi

            if [[ -z "${DISCOVERY_E2E_MODE:-}" ]]; then
                echo "[INFO] 未显式指定 discovery mode，e2e 将依次运行 CPU 和 GPU 两种模式。"
                DISCOVERY_E2E_MODE=cpu just test e2e {{args}}
                DISCOVERY_E2E_MODE=gpu just test e2e {{args}}
                exit 0
            fi

            ensure_test_ready

            ensure_logs_dir

            e2e_log_file="{{test_e2e_log_file}}"
            e2e_host="${DISCOVERY_E2E_HOST:-127.0.0.1}"
            e2e_port="${DISCOVERY_E2E_PORT:-}"
            if [[ -z "${e2e_port}" ]]; then
                e2e_port="$(find_free_port)"
            fi
            e2e_base_url="http://${e2e_host}:${e2e_port}"
            e2e_mode="${DISCOVERY_E2E_MODE:-cpu}"
            e2e_health_url="${DISCOVERY_E2E_HEALTH_URL:-}"
            e2e_pid=""
            started_e2e=0

            validate_test_e2e_base_url "${e2e_base_url}"

            if [[ -z "${e2e_health_url}" ]]; then
                e2e_health_url="${e2e_base_url}/acps-adp-v2/health"
            fi

            cleanup_e2e() {
                if [[ "${started_e2e}" -eq 1 ]] && [[ -n "${e2e_pid}" ]] && kill -0 "${e2e_pid}" 2>/dev/null; then
                    stop_pid "${e2e_pid}"
                    echo "[INFO] 已停止临时 e2e 测试实例。"
                fi
            }

            trap cleanup_e2e EXIT

            embedding_api_key="${DISCOVERY_E2E_EMBEDDING_API_KEY:-$(resolve_local_env_value EMBEDDING_API_KEY)}"
            embedding_base_url="${DISCOVERY_E2E_EMBEDDING_BASE_URL:-$(resolve_local_env_value EMBEDDING_BASE_URL)}"
            embedding_model_name="${DISCOVERY_E2E_EMBEDDING_MODEL_NAME:-$(resolve_local_env_value EMBEDDING_MODEL_NAME)}"
            embedding_model_path="${DISCOVERY_E2E_EMBEDDING_MODEL_PATH:-$(resolve_local_env_value EMBEDDING_MODEL_PATH)}"
            embedding_devices="${DISCOVERY_E2E_EMBEDDING_DEVICES:-$(resolve_local_env_value EMBEDDING_DEVICES)}"
            reranker_url="${DISCOVERY_E2E_RERANKER_URL:-$(resolve_local_env_value RERANKER_URL)}"
            discovery_llm_api_key="${DISCOVERY_E2E_DISCOVERY_LLM_API_KEY:-$(resolve_local_env_value DISCOVERY_LLM_API_KEY)}"
            discovery_llm_base_url="${DISCOVERY_E2E_DISCOVERY_LLM_BASE_URL:-$(resolve_local_env_value DISCOVERY_LLM_BASE_URL)}"
            discovery_llm_model_name="${DISCOVERY_E2E_DISCOVERY_LLM_MODEL_NAME:-$(resolve_local_env_value DISCOVERY_LLM_MODEL_NAME)}"

            if [[ -z "${embedding_api_key}" ]]; then
                embedding_api_key="e2e-test-key"
            fi
            if [[ -z "${embedding_base_url}" ]]; then
                embedding_base_url="http://127.0.0.1:9/v1"
            fi
            if [[ -z "${embedding_model_name}" ]]; then
                embedding_model_name="e2e-test-model"
            fi
            if [[ -z "${discovery_llm_api_key}" ]]; then
                discovery_llm_api_key="e2e-test-key"
            fi
            if [[ -z "${discovery_llm_base_url}" ]]; then
                discovery_llm_base_url="http://127.0.0.1:9/v1"
            fi
            if [[ -z "${discovery_llm_model_name}" ]]; then
                discovery_llm_model_name="e2e-test-discovery-model"
            fi

            : >"${e2e_log_file}"

            if [[ "${e2e_mode}" == "cpu" ]]; then
                nohup env \
                    PYTHONPATH="$PWD" \
                    APP_ENV=testing \
                    DATABASE_URL="${test_database_url}" \
                    UVICORN_HOST="${e2e_host}" \
                    UVICORN_PORT="${e2e_port}" \
                    DISCOVERY_MODE="${e2e_mode}" \
                    EMBEDDING_API_KEY="${embedding_api_key}" \
                    EMBEDDING_BASE_URL="${embedding_base_url}" \
                    EMBEDDING_MODEL_NAME="${embedding_model_name}" \
                    DISCOVERY_LLM_API_KEY="${discovery_llm_api_key}" \
                    DISCOVERY_LLM_BASE_URL="${discovery_llm_base_url}" \
                    DISCOVERY_LLM_MODEL_NAME="${discovery_llm_model_name}" \
                    DSP_AUTO_START=false \
                    FORWARDER_SERVER_ENABLED=false \
                    DSP_BASE_URL="http://127.0.0.1:9/acps-dsp-v2" \
                    POLLING_SERVER_URL="http://127.0.0.1:9" \
                    uv run python -m app.main >>"${e2e_log_file}" 2>&1 &
            else
                nohup env \
                    PYTHONPATH="$PWD" \
                    APP_ENV=testing \
                    DATABASE_URL="${test_database_url}" \
                    UVICORN_HOST="${e2e_host}" \
                    UVICORN_PORT="${e2e_port}" \
                    DISCOVERY_MODE="${e2e_mode}" \
                    EMBEDDING_MODEL_PATH="${embedding_model_path}" \
                    EMBEDDING_DEVICES="${embedding_devices}" \
                    RERANKER_URL="${reranker_url}" \
                    DISCOVERY_LLM_API_KEY="${discovery_llm_api_key}" \
                    DISCOVERY_LLM_BASE_URL="${discovery_llm_base_url}" \
                    DISCOVERY_LLM_MODEL_NAME="${discovery_llm_model_name}" \
                    DSP_AUTO_START=false \
                    FORWARDER_SERVER_ENABLED=false \
                    DSP_BASE_URL="http://127.0.0.1:9/acps-dsp-v2" \
                    POLLING_SERVER_URL="http://127.0.0.1:9" \
                    uv run python -m app.main >>"${e2e_log_file}" 2>&1 &
            fi
            e2e_pid=$!
            started_e2e=1
            echo "[INFO] 已启动临时 e2e 测试实例：${e2e_base_url}（PID=${e2e_pid}，mode=${e2e_mode}）。"

            if ! uv run python scripts/wait_for_http.py \
                "${e2e_health_url}" \
                --expect-status 200 \
                --expect-json-key status \
                --expect-json-value healthy; then
                echo "[ERROR] e2e 测试实例未能按时通过健康检查，请检查 ${e2e_log_file}。" >&2
                tail -n 200 "${e2e_log_file}" >&2 || true
                exit 1
            fi

            TEST_DATABASE_URL="${test_database_url}" TEST_E2E_BASE_URL="${e2e_base_url}" DISCOVERY_E2E_BASE_URL="${e2e_base_url}" uv run pytest tests/e2e {{args}}
            ;;
        all|"")
            just test unit {{args}}
            just test integration {{args}}
            just test e2e {{args}}
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all':
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        fmt)
            uv run ruff format .
            ;;
        fix)
            just qa fmt
            uv run ruff check --fix .
            ;;
        lint)
            uv run ruff check .
            ;;
        type-app)
            uv run mypy --config-file pyproject.toml app main.py
            ;;
        type-tests)
            uv run mypy --config-file pyproject.toml tests
            ;;
        type-strict-coverage)
            uv run python scripts/check_mypy_strict_coverage.py
            ;;
        security)
            uv run bandit -c pyproject.toml -r app scripts main.py
            ;;
        audit)
            uv run pip-audit
            ;;
        full)
            just qa lint
            just qa type-app
            just qa type-tests
            just qa type-strict-coverage
            just qa security
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        all|"")
            just qa fix
            just qa precommit
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac
