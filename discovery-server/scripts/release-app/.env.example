# 共享基础设施模式下的应用环境变量
# 仅包含敏感/部署专用配置，非敏感业务参数请修改 config/ 下的 TOML 文件

# ── 部署路径 ──

# stage 网关中的一级路径前缀（不带前导 /）
APP_PATH_PREFIX=discovery

# FastAPI 对外暴露的根路径，需与 APP_PATH_PREFIX 一致
ROOT_PATH=/discovery

# 基础连通性验证访问地址
APP_BASE_URL=http://localhost:9000/discovery

# ── 应用环境 ──
APP_ENV=production

# ── 数据库 ──

# 必须指向已存在且已启用 pgvector 的 stage-postgres
DATABASE_URL=postgresql+asyncpg://discovery:discovery@stage-postgres:5432/agent_discovery

# ── DSP / Forwarder / Polling 依赖地址 ──

# 默认对接同机 stage-infra + registry-server release-app。
DSP_BASE_URL=http://stage-nginx:9000/registry/acps-dsp-v2

# 若 polling / forwarder 不与当前宿主机同机部署，请改成真实可访问地址。
POLLING_SERVER_URL=http://host.docker.internal:8020
FORWARDER_SERVER_URL=
FORWARDER_SERVER_ENABLED=false

# ── 发现运行模式 ──
DISCOVERY_MODE=cpu

# ── Discovery LLM（OpenAI 兼容） ──
DISCOVERY_LLM_MODEL_NAME=qwen-plus
DISCOVERY_LLM_API_KEY=
DISCOVERY_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── CPU 模式 embedding ──
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# ── GPU 模式本地模型 / reranker ──
EMBEDDING_MODEL_PATH=/models/embedding
EMBEDDING_DEVICES=cuda:0
RERANKER_URL=

# ── Prompt 文件（如独立挂载） ──
PROMPT_FILE_PATH=/prompts/planner_prompt.txt
CLUSTER_PROMPT_FILE_PATH=/prompts/cluster_prompt.txt

# ── DSP Webhook ──
DSP_WEBHOOK_SECRET=change-me
