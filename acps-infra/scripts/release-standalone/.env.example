# standalone 单机版发布包顶层配置模板，仅用于 same-host 全新安装。
# 安装器会先清理本流程管理的 Docker 资源和卷，不用于原地升级。
# 推荐流程：cp .env.example .env -> 填写真实 LLM / 密码 -> bash install.sh

# ===== 安装行为 =====
INSTALL_ROOT=./runtime
RUN_BUSINESS_SMOKE=true
# 当 RUN_BUSINESS_SMOKE=false 时，安装器默认进入 infra-only 模式并跳过 demo-apps 部署。
# 如需在跳过业务烟测的同时仍部署 demo-apps，可显式设置为 true。
# DEPLOY_DEMO_APPS=true
# 高级可选项：通常不需要设置。
# 如需覆盖业务烟测默认超时，可自行取消注释：
# BUSINESS_HTTP_REQUEST_TIMEOUT=240
# BUSINESS_TASK_POLL_TIMEOUT=600
# BUSINESS_GROUP_POLL_TIMEOUT=600

# ===== stage gateway 与同机访问 =====
# 浏览器与宿主机 smoke 访问 stage-nginx 的地址。
GATEWAY_PUBLIC_HOST=localhost
# release-app 容器位于 stage-net 内部，默认直接通过服务名访问 stage-nginx。
GATEWAY_SERVICE_HOST=stage-nginx
# demo 容器与工具镜像回退路径默认通过 host-gateway 访问宿主机发布的 stage 网关。
GATEWAY_BRIDGE_HOST=host.docker.internal
# install.sh 会将其映射到 stage-infra/.env 中的 NGINX_PORT。
STAGE_NGINX_PORT=9000

# ===== stage-infra =====
POSTGRES_INIT_USER=postgres
POSTGRES_INIT_PASSWORD=postgres
POSTGRES_INIT_DB=postgres

REGISTRY_DB_USER=registry
REGISTRY_DB_PASSWORD=registry
REGISTRY_DB_NAME=agent_registry

CA_DB_USER=ca
CA_DB_PASSWORD=ca
CA_DB_NAME=agent_ca

DISCOVERY_DB_USER=discovery
DISCOVERY_DB_PASSWORD=discovery
DISCOVERY_DB_NAME=agent_discovery

REDIS_PASSWORD=change-me
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me
# 若仍为 change-me，安装器会自动生成随机值，并在所有相关容器 .env 中复用该值。
RABBITMQ_PORT=5671
MQ_AUTH_PORT=9007
MQ_AUTH_MGMT_USER=mq-auth-svc
MQ_AUTH_MGMT_PASS=change-me
# 若仍为 change-me，安装器会自动生成随机值，并在 stage-infra / mq-auth-server 中保持一致。

# ===== registry-server release-app =====
# 可选。留空则由 registry-server deploy.sh 在当前首装中自动生成并写回其 .env。
REGISTRY_SECRET_KEY=
# 可选。留空则由 registry-server deploy.sh 在当前首装中自动生成并写回其 .env。
REGISTRY_AIC_CRC_SALT=
# `9002` mTLS 对外发布主机；留空则默认回退到 GATEWAY_PUBLIC_HOST。
REGISTRY_SERVER_MTLS_PUBLIC_HOST=
# `9002` mTLS 对外发布端口。
REGISTRY_SERVER_MTLS_PORT=9002
# registry-server 与 ca-server 的服务间 internal API 认证令牌；留空时由安装器自动生成随机值。
REGISTRY_SERVER_INTERNAL_API_TOKEN=
# registry-server SMTP / 邮件发送（敏感；留空则按 registry-server config/*.toml 回退）
REGISTRY_SMTP_SERVER=
REGISTRY_SMTP_PORT=
REGISTRY_EMAIL_ADDRESS=
REGISTRY_EMAIL_PASSWORD=

# ===== ca-server release-app =====
# 若为 false，安装器会把下面 4 个源文件复制到 runtime/ca-server/certs/。
# 路径支持绝对路径，或相对当前 standalone 解压目录的路径。
AUTO_GENERATE_CA_MATERIALS=true
CA_CERT_SOURCE_PATH=
CA_KEY_SOURCE_PATH=
CA_CHAIN_SOURCE_PATH=
CA_TRUST_BUNDLE_SOURCE_PATH=

# ===== discovery-server release-app =====
# 运行档位：cpu 走远端 embedding API，gpu 走本地模型路径。
DISCOVERY_MODE=cpu

# 以下参数必须由顶层 .env 显式提供；安装器不会再从 sibling 项目或工作区自动回填。
DISCOVERY_LLM_API_KEY=
# 以下示例使用阿里云百炼 OpenAI 兼容接口的北京地域地址；如使用其它地域请替换。
DISCOVERY_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DISCOVERY_LLM_MODEL_NAME=qwen-plus

# CPU 模式 embedding
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL_NAME=text-embedding-3-small
# cpu 模式留空时由 install.sh 按模型名自动推断；gpu 模式请显式填写真实维度。
EMBEDDING_DIM=

# GPU 模式本地模型 / reranker
EMBEDDING_MODEL_PATH=/models/embedding
EMBEDDING_DEVICES=cuda:0
RERANKER_URL=
# DSP webhook 共享密钥；保留 change-me 时由安装器自动生成随机值。
DSP_WEBHOOK_SECRET=change-me

# ===== acps-cli bootstrap =====
# client 账号用于普通用户侧操作；若不存在，acps-cli 首次 auth login 会自动注册该用户。
REGISTRY_CLIENT_USERNAME=demo-client
REGISTRY_CLIENT_PASSWORD=demo123
# admin 账号用于审核/审批等管理员操作；必须与 registry-server 数据库中的现有管理员一致。
# 首装默认 admin/admin123 由 registry-server release-app 的 `alembic upgrade head` 自动写入数据库。
REGISTRY_ADMIN_USERNAME=admin
REGISTRY_ADMIN_PASSWORD=admin123

# ===== demo-leader =====
# demo-leader Web UI 对外发布端口。
LEADER_WEB_PORT=9010

LEADER_LLM_FAST_API_KEY=
LEADER_LLM_FAST_BASE_URL=
LEADER_LLM_FAST_MODEL=doubao-seed-1-6-flash-250828

LEADER_LLM_DEFAULT_API_KEY=
LEADER_LLM_DEFAULT_BASE_URL=
LEADER_LLM_DEFAULT_MODEL=Doubao-pro-32k

LEADER_LLM_PRO_API_KEY=
LEADER_LLM_PRO_BASE_URL=
LEADER_LLM_PRO_MODEL=qwen3-max

# ===== demo-partner =====
PARTNER_LLM_FAST_API_KEY=
PARTNER_LLM_FAST_BASE_URL=
PARTNER_LLM_FAST_MODEL=doubao-seed-1-6-flash-250828

PARTNER_LLM_DEFAULT_API_KEY=
PARTNER_LLM_DEFAULT_BASE_URL=
PARTNER_LLM_DEFAULT_MODEL=Doubao-pro-32k
