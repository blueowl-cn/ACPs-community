# 同机 stage-infra + release-app 验证场景下，可直接 cp .env.example .env 后执行 bash deploy.sh。
# 正式环境请至少替换各类密码，并按组织要求调整端口。

# PostgreSQL 超级用户（仅用于初始化，不对应用暴露）
POSTGRES_INIT_USER=postgres
POSTGRES_INIT_PASSWORD=postgres
POSTGRES_INIT_DB=postgres

# registry-server 数据库凭证（密码不得包含单引号）
REGISTRY_DB_USER=registry
REGISTRY_DB_PASSWORD=registry
REGISTRY_DB_NAME=agent_registry

# ca-server 数据库凭证（密码不得包含单引号）
CA_DB_USER=ca
CA_DB_PASSWORD=ca
CA_DB_NAME=agent_ca

# discovery-server 数据库凭证（密码不得包含单引号）
DISCOVERY_DB_USER=discovery
DISCOVERY_DB_PASSWORD=discovery
DISCOVERY_DB_NAME=agent_discovery

REDIS_PASSWORD=change-me
NGINX_PORT=9000

RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me
RABBITMQ_PORT=5671

MQ_AUTH_PORT=9007
MQ_AUTH_MGMT_USER=mq-auth-svc
MQ_AUTH_MGMT_PASS=change-me

STAGE_INFRA_NETWORK=stage-net
