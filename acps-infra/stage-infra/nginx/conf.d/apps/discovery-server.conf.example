# discovery-server 应用路由配置（由 discovery-server deploy.sh 自动生成，此为示例）
# 实际文件路径：nginx/conf.d/apps/discovery.conf
# 应用端口：9005  容器名：discovery-server-blue / discovery-server-green

location = /discovery {
    return 301 /discovery/;
}

location = /discovery/health {
    rewrite ^/discovery(/.*)$ $1 break;
    proxy_pass http://discovery-server-blue:9005;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /discovery;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}

location ~ ^/discovery/(ready|metrics)$ {
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    allow 127.0.0.1;
    allow ::1;
    deny all;

    rewrite ^/discovery(/.*)$ $1 break;
    proxy_pass http://discovery-server-blue:9005;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /discovery;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}

location /discovery/ {
    proxy_pass http://discovery-server-blue:9005/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /discovery;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}
