# registry-server 应用路由配置（由 registry-server deploy.sh 自动生成，此为示例）
# 实际文件路径：nginx/conf.d/apps/registry.conf
# 应用端口：9001  容器名：registry-server-blue / registry-server-green

location = /registry {
    return 301 /registry/;
}

location = /registry/health {
    rewrite ^/registry(/.*)$ $1 break;
    proxy_pass http://registry-server-blue:9001;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /registry;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}

location ~ ^/registry/(ready|metrics)$ {
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    allow 127.0.0.1;
    allow ::1;
    allow fc00::/7;
    allow fe80::/10;
    deny all;

    rewrite ^/registry(/.*)$ $1 break;
    proxy_pass http://registry-server-blue:9001;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /registry;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}

location /registry/ {
    proxy_pass http://registry-server-blue:9001/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /registry;
    proxy_set_header X-Request-ID $request_id;

    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    proxy_send_timeout 10s;
}
