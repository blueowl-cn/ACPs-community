# demo-apps 一键注册/审批/证书 + Discovery 配置
# 默认值已按 same-host stage-infra + release-app 拓扑预填。
# 复制为 provision.conf 后可直接执行 bash provision.sh setup，无需编辑。
# provision.sh 会读取本文件，并按需生成传给 acps-cli 的运行时配置。

# 如果脚本在容器内执行（Dev Container / 工具镜像回退），通常使用 host.docker.internal。
# 如果脚本直接在宿主机执行，provision.sh 会自动将 host.docker.internal 规范化为 localhost。

# ===== Registry Server =====
REGISTRY_API_BASE_URL = http://host.docker.internal:9000/registry/api
# 普通用户侧登录凭据；若该用户不存在，acps-cli 首次 auth login 会自动注册。
REGISTRY_CLIENT_USERNAME = demo-client
REGISTRY_CLIENT_PASSWORD = demo123
# 管理员登录凭据；必须与 registry-server 数据库中的现有管理员一致。
# 首装默认 admin/admin123 由 registry-server release-app 的 alembic upgrade head 自动写入数据库。
REGISTRY_ADMIN_USERNAME = admin
REGISTRY_ADMIN_PASSWORD = admin123

# ===== CA Server =====
CA_SERVER_BASE_URL = http://host.docker.internal:9000/ca-server

# ===== Discovery Server =====
# DSP sync 触发端点及查询接口（通过网关暴露）。
# 留空则使用默认值 http://host.docker.internal:9000/discovery
DISCOVERY_GATEWAY_URL = http://host.docker.internal:9000/discovery
