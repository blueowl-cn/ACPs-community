set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

project_name := "demo-leader"
dev_infra_script := "../acps-infra/dev-infra/dev-infra.sh"
dev_pki_script := "../acps-infra/dev-infra/dev-cert.sh"
leader_pid_file := "logs/leader.pid"
web_pid_file := "logs/static_web.pid"
leader_log_file := "logs/leader.log"
web_log_file := "logs/static_web.log"

default:
    @just help

help:
        @echo "demo-leader Just 命令"
        @echo ""
        @echo "用法："
        @echo "  just app [action] [args...]"
        @echo "  just test [action] [args...]"
        @echo "  just qa [action] [args...]"
        @echo "  just package [action] [args...]"
        @echo "  just infra [action] [args...]"
        @echo "  just doctor"
        @echo "  just prep [action] [args...]"
        @echo ""
        @echo "app：本地应用生命周期"
        @echo "  bootstrap        建立开发环境（infra up rabbitmq + prep env + prep sync + prep hooks + prep certs）"
        @echo "  start            后台启动 Leader API + Web UI（默认动作）"
        @echo "  start bg         显式后台启动 Leader API + Web UI"
        @echo "  start fg         前台启动 Leader API；默认同时后台拉起 Web UI"
        @echo "  stop             停止后台实例"
        @echo "  status           查看后台实例状态"
        @echo "  logs             查看后台日志末尾 200 行"
        @echo "  logs follow      持续跟随后台日志"
        @echo "  restart          重启后台实例"
        @echo "  smoke            执行本地开发基础冒烟"
        @echo ""
        @echo "test：测试入口"
        @echo "  bootstrap        建立测试环境（infra up rabbitmq + prep env + prep sync + prep hooks + prep certs）"
        @echo "  unit             运行单元测试；支持透传 pytest 参数"
        @echo "  api              运行进程内 API 测试；支持透传 pytest 参数"
        @echo "  coverage         运行单元测试覆盖率门禁（fail-under=70）"
        @echo "  integration      执行 doctor 后运行集成测试"
        @echo "  e2e              执行 doctor 后运行端到端测试"
        @echo "  all              依次执行 unit -> api -> integration -> e2e"
        @echo ""
        @echo "qa：代码质量入口"
        @echo "  fmt              执行 ruff format ."
        @echo "  type             执行 mypy leader/"
        @echo "  fix              执行 format + ruff check --fix"
        @echo "  precommit        执行 pre-commit run --all-files"
        @echo "  all              依次执行 fix -> precommit"
        @echo ""
        @echo "package：原生 wheel 运行包构建"
        @echo "  wheel            构建在线运行包（demo-leader + acps-cli + acps-sdk wheel）"
        @echo "  wheel offline    构建包含 Python 运行时依赖 wheelhouse 的离线包"
        @echo ""
        @echo "infra：共享依赖管理"
        @echo "  status [service...] [--format=tsv]   查看共享依赖状态"
        @echo "  up [service...]                      启动共享依赖，默认 rabbitmq"
        @echo "  down                                 停止共享依赖"
        @echo "  wait [service...]                    等待共享依赖就绪"
        @echo "  logs [service...] [--follow]         查看共享依赖日志"
        @echo "  reset [service...] [--volumes --yes] 修复性重建共享依赖"
        @echo "  doctor                               检查共享 infra 环境"
        @echo ""
        @echo "doctor：只读环境检查"
        @echo "  检查 uv / .venv Python / just / openssl / .env / uv sync 状态 / dev-infra / RabbitMQ 健康状态"
        @echo "  并校验 leader/atr 下的本地 mTLS 开发证书是否齐备（缺失时可执行 just prep certs 基于 acs.json 重签）"
        @echo ""
        @echo "prep：维护与局部修复动作"
        @echo "  env      缺失时根据 .env.example 生成 .env"
        @echo "  sync     强制使用 managed Python 3.14 同步依赖"
        @echo "  hooks    安装/更新 pre-commit 与 commit-msg hooks"
        @echo "  certs    基于 leader/atr/acs.json 声明并签发 leader/atr 下的本地 mTLS 开发证书"
        @echo ""
        @echo "常用示例："
        @echo "  just app bootstrap"
        @echo "  just prep certs"
        @echo "  just app start"
        @echo "  just app smoke"
        @echo "  just app stop"
        @echo "  just test"
        @echo "  just package wheel"
        @echo "  just package wheel offline"
        @echo "  just qa"

infra action='status' *args:
    @{{dev_infra_script}} {{action}} {{args}}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0
    infra_ok=1
    skip_openssl_check="${SKIP_OPENSSL_DOCTOR:-0}"
    skip_dotenv_check="${SKIP_DOTENV_DOCTOR:-0}"
    skip_local_path_check="${SKIP_LOCAL_PATH_DOCTOR:-0}"
    skip_shared_infra_check="${SKIP_SHARED_INFRA_DOCTOR:-0}"

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    elif ! uv run --no-sync python -c 'import sys; raise SystemExit(0 if sys.version_info[:2] == (3, 14) else 1)' >"${tmpfile}" 2>&1; then
        echo "[ERROR] .venv Python 版本不满足 pyproject.toml 要求（需要 >=3.14,<3.15）。请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if [[ "${skip_openssl_check}" == "1" ]]; then
        echo "[INFO]  跳过 openssl 检查（SKIP_OPENSSL_DOCTOR=1）。"
    elif ! command -v openssl >/dev/null 2>&1; then
        echo "[ERROR] 未找到 openssl；just prep certs 依赖共享开发 PKI 脚本使用 openssl。" >&2
        issues=$((issues + 1))
    fi

    if [[ "${skip_dotenv_check}" == "1" ]]; then
        echo "[INFO]  跳过 .env 检查（SKIP_DOTENV_DOCTOR=1）。"
    elif [[ ! -f .env ]]; then
        echo "[ERROR] 未找到 .env，请先执行 just prep env。" >&2
        issues=$((issues + 1))
    fi

    if [[ "${skip_local_path_check}" == "1" ]]; then
        echo "[INFO]  跳过兄弟项目路径检查（SKIP_LOCAL_PATH_DOCTOR=1）。"
    else
        if [[ ! -d ../acps-sdk ]]; then
            echo "[ERROR] 未找到兄弟项目 ../acps-sdk，当前仓库依赖该本地路径。" >&2
            issues=$((issues + 1))
        fi

        if [[ ! -d ../acps-cli ]]; then
            echo "[ERROR] 未找到兄弟项目 ../acps-cli，当前仓库依赖该本地路径。" >&2
            issues=$((issues + 1))
        fi
    fi

    for cert_path in leader/atr/client.pem leader/atr/client.key leader/atr/trust-bundle.pem; do
        if [[ ! -f "${cert_path}" ]]; then
            echo "[ERROR] 本地 mTLS 开发证书缺失：${cert_path}。请先执行 just prep certs。" >&2
            issues=$((issues + 1))
        fi
    done

    if [[ "${skip_shared_infra_check}" == "1" ]]; then
        echo "[INFO]  跳过共享 infra 检查（SKIP_SHARED_INFRA_DOCTOR=1）。"
    else
        if [[ ! -x {{dev_infra_script}} ]]; then
            echo "[ERROR] 未找到共享 infra 工具：{{dev_infra_script}}" >&2
            issues=$((issues + 1))
            infra_ok=0
        elif ! just infra doctor >"${tmpfile}" 2>&1; then
            echo "[ERROR] 共享 infra 工具检查失败。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
            infra_ok=0
        fi

        if [[ "${infra_ok}" -eq 1 ]]; then
            if ! status_output="$(just infra status rabbitmq --format=tsv 2>"${tmpfile}")"; then
                echo "[ERROR] 无法读取共享 RabbitMQ 状态。" >&2
                cat "${tmpfile}" >&2
                issues=$((issues + 1))
            elif [[ -z "${status_output}" ]]; then
                echo "[ERROR] 共享 RabbitMQ 状态输出为空。" >&2
                issues=$((issues + 1))
            else
                IFS=$'\t' read -r service _mode state health _ports <<<"${status_output%%$'\n'*}"

                if [[ "${service}" != "rabbitmq" ]]; then
                    echo "[ERROR] 共享 RabbitMQ 状态输出格式异常：${status_output}" >&2
                    issues=$((issues + 1))
                else
                    if [[ "${state}" != "running" ]]; then
                        echo "[ERROR] 共享 RabbitMQ 未运行（state=${state}）。请先执行 just infra up rabbitmq。" >&2
                        issues=$((issues + 1))
                    fi

                    if [[ "${health}" != "healthy" ]]; then
                        echo "[ERROR] 共享 RabbitMQ 未健康（health=${health}）。" >&2
                        issues=$((issues + 1))
                    fi
                fi
            fi
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO]  doctor checks passed for {{project_name}}"

_bootstrap_common:
    @just infra up rabbitmq
    @just prep env
    @just prep sync
    @just prep hooks
    @just prep certs

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    print_help() {
        echo "prep 维护动作："
        echo "  just prep env    缺失时根据 .env.example 生成 .env"
        echo "  just prep sync   强制使用 managed Python 3.14 同步依赖"
        echo "  just prep hooks  安装/更新 pre-commit 与 commit-msg hooks"
        echo "  just prep certs  基于 leader/atr/acs.json 声明并签发 leader/atr 下的本地 mTLS 开发证书"
    }

    install_git_hooks() {
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "[WARN]  当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            return
        fi

        uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
        echo "[INFO]  已安装或更新 pre-commit / commit-msg hooks。"
    }

    run_bootstrap_python() {
        UV_MANAGED_PYTHON=1 uv run --python 3.14 --managed-python --no-project python "$@"
    }

    extract_aic_from_acs() {
        local acs_path="$1"
        run_bootstrap_python -c 'import json, sys; from pathlib import Path; data = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8")); aic = data.get("aic") or data.get("agentAic"); sys.exit(1) if not isinstance(aic, str) or not aic.strip() else None; print(aic.strip())' "${acs_path}"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO]  .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                echo "[INFO]  已根据 .env.example 生成 .env。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            install_git_hooks
            ;;
        certs)
            if ! command -v openssl >/dev/null 2>&1; then
                echo "[ERROR] 未找到 openssl，just prep certs 依赖共享开发 PKI 脚本使用 openssl。" >&2
                exit 1
            fi

            if [[ ! -x "{{dev_pki_script}}" ]]; then
                echo "[ERROR] 未找到共享开发 PKI 脚本：{{dev_pki_script}}" >&2
                exit 1
            fi

            if ! leader_aic="$(extract_aic_from_acs leader/atr/acs.json)"; then
                echo "[ERROR] 无法从 leader/atr/acs.json 提取 Leader AIC。" >&2
                exit 1
            fi

            bash "{{dev_pki_script}}" issue-leaf \
                --ca agent \
                --common-name "${leader_aic}" \
                --usage clientAuth \
                --cert-out "leader/atr/client.pem" \
                --key-out "leader/atr/client.key" \
                --bundle-out "leader/atr/trust-bundle.pem" \
                --relative-to "$PWD"

            for required_file in leader/atr/client.pem leader/atr/client.key leader/atr/trust-bundle.pem; do
                if [[ ! -f "${required_file}" ]]; then
                    echo "[ERROR] 共享开发 PKI 签发完成后仍缺少证书文件：${required_file}" >&2
                    exit 1
                fi
            done

            echo "[INFO]  共享开发 PKI 已按 leader/atr/acs.json 签发 Leader 本地 mTLS 开发证书。"
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

app action='start' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    leader_pid_file="{{leader_pid_file}}"
    web_pid_file="{{web_pid_file}}"
    leader_log_file="{{leader_log_file}}"
    web_log_file="{{web_log_file}}"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    ensure_log_dir() {
        mkdir -p logs
    }

    read_live_pid() {
        local target_pid_file="$1"

        if [[ ! -f "${target_pid_file}" ]]; then
            return 1
        fi

        local pid
        pid="$(tr -d '[:space:]' < "${target_pid_file}")"
        if [[ -z "${pid}" ]]; then
            rm -f "${target_pid_file}"
            return 1
        fi

        if kill -0 "${pid}" 2>/dev/null; then
            printf '%s\n' "${pid}"
            return 0
        fi

        rm -f "${target_pid_file}"
        return 1
    }

    ensure_background_process() {
        local name="$1"
        local target_pid_file="$2"
        local target_log_file="$3"
        shift 3

        local pid
        if pid="$(read_live_pid "${target_pid_file}")"; then
            echo "[INFO]  ${name} 已在后台运行（pid=${pid}）。"
            return 1
        fi

        nohup "$@" >> "${target_log_file}" 2>&1 &
        pid=$!
        echo "${pid}" > "${target_pid_file}"

        sleep 2
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${target_pid_file}"
            echo "[ERROR] ${name} 启动失败，请检查 ${target_log_file}。" >&2
            exit 1
        fi

        echo "[INFO]  ${name} 已在后台启动（pid=${pid}）。"
        return 0
    }

    stop_background_process() {
        local name="$1"
        local target_pid_file="$2"
        local pid

        if ! pid="$(read_live_pid "${target_pid_file}")"; then
            echo "[INFO]  ${name} 当前未在后台运行。"
            return 0
        fi

        kill "${pid}" 2>/dev/null || true
        sleep 1
        if kill -0 "${pid}" 2>/dev/null; then
            kill -9 "${pid}" 2>/dev/null || true
            sleep 1
        fi

        rm -f "${target_pid_file}"
        echo "[INFO]  ${name} 已停止（pid=${pid}）。"
    }

    show_status() {
        local name="$1"
        local target_pid_file="$2"
        local pid

        if pid="$(read_live_pid "${target_pid_file}")"; then
            echo "[INFO]  ${name}: RUNNING (pid=${pid})"
        else
            echo "[INFO]  ${name}: STOPPED"
        fi
    }

    collect_log_files() {
        local -a log_files=()

        [[ -f "${leader_log_file}" ]] && log_files+=("${leader_log_file}")
        [[ -f "${web_log_file}" ]] && log_files+=("${web_log_file}")

        if [[ "${#log_files[@]}" -eq 0 ]]; then
            echo "[ERROR] 未找到后台日志文件，请先执行 just app start。" >&2
            exit 1
        fi

        printf '%s\n' "${log_files[@]}"
    }

    run_leader_foreground() {
        UVICORN_RELOAD=true bash scripts/start-leader-api.sh
    }

    start_leader_background() {
        ensure_background_process \
            "leader" \
            "${leader_pid_file}" \
            "${leader_log_file}" \
            env UVICORN_RELOAD=true \
            bash scripts/start-leader-api.sh
    }

    start_web_background() {
        ensure_background_process \
            "static_web" \
            "${web_pid_file}" \
            "${web_log_file}" \
            bash scripts/start-web-ui.sh
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            ;;
        start)
            just doctor
            load_dotenv
            ensure_log_dir

            if [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "fg" ]]; then
                web_started=0
                echo "[INFO]  启动 {{project_name}}（前台 Leader，后台 Web）..."
                if start_web_background; then
                    web_started=1
                fi
                cleanup() {
                    if [[ "${web_started}" -eq 1 ]]; then
                        stop_background_process "static_web" "${web_pid_file}" >/dev/null 2>&1 || true
                    fi
                }
                trap cleanup EXIT INT TERM
                run_leader_foreground
                exit 0
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" != "bg" ]]; then
                echo "[ERROR] 未知 app start 参数：${requested_args[*]}。支持：bg / fg" >&2
                exit 2
            fi

            if start_leader_background; then
                :
            fi
            if start_web_background; then
                :
            fi
            echo "[INFO]  {{project_name}} 已在后台启动。"
            echo "[INFO]  执行 just app status 查看进程状态。"
            ;;
        stop)
            stop_background_process "leader" "${leader_pid_file}"
            stop_background_process "static_web" "${web_pid_file}"
            ;;
        status)
            show_status "leader" "${leader_pid_file}"
            show_status "static_web" "${web_pid_file}"
            ;;
        logs)
            mapfile -t log_files < <(collect_log_files)

            if [[ "${args_string}" == "follow" ]]; then
                exec tail -f "${log_files[@]}"
            fi

            tail -n 200 "${log_files[@]}"
            ;;
        restart)
            just app stop
            if [[ -n "${args_string}" ]] && [[ "${args_string}" != "bg" ]]; then
                echo "[ERROR] app restart 只管理后台实例；如需前台运行，请直接执行 just app start fg。" >&2
                exit 2
            fi
            just app start
            ;;
        smoke)
            WEB_BASE_URL="${WEB_BASE_URL:-http://localhost:9010}" \
            LEADER_HEALTH_URL="${LEADER_HEALTH_URL:-http://localhost:9011/api/v1/health}" \
            bash scripts/smoke-test.sh
            ;;
        *)
            echo "[ERROR] 未知 app action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    default_loadfile_workers="${JUST_TEST_LOADFILE_WORKERS:-2}"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    if [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "--" ]]; then
        requested_args=("${requested_args[@]:1}")
    fi

    has_explicit_xdist_args() {
        local expect_plugin_name=0
        local arg

        for arg in "$@"; do
            if [[ "${expect_plugin_name}" -eq 1 ]]; then
                if [[ "${arg}" == "no:xdist" ]]; then
                    return 0
                fi
                expect_plugin_name=0
                continue
            fi

            case "${arg}" in
                -n|--numprocesses|--dist|-d)
                    return 0
                    ;;
                -n=*|--numprocesses=*|--dist=*|-pno:xdist)
                    return 0
                    ;;
                -p)
                    expect_plugin_name=1
                    ;;
            esac
        done

        return 1
    }

    run_scoped_pytest() {
        local default_path="$1"
        local parallel_mode="$2"
        shift 2
        local selection_count="$#"
        local -a selection=()
        local -a parallel_args=()
        local -a pytest_cmd=(uv run pytest)

        if [[ "${selection_count}" -gt 0 ]]; then
            selection=("$@")
        fi

        if [[ "${parallel_mode}" == "loadfile" ]]; then
            if [[ "${selection_count}" -eq 0 ]] || ! has_explicit_xdist_args "${selection[@]}"; then
                parallel_args=(-n "${default_loadfile_workers}" --dist=loadfile)
            fi
        fi

        if [[ "${selection_count}" -eq 0 ]]; then
            pytest_cmd+=("${default_path}")
            if [[ "${#parallel_args[@]}" -gt 0 ]]; then
                pytest_cmd+=("${parallel_args[@]}")
            fi
            "${pytest_cmd[@]}"
            return
        fi

        if [[ "${selection[0]}" == -* ]]; then
            pytest_cmd+=("${default_path}")
            if [[ "${#parallel_args[@]}" -gt 0 ]]; then
                pytest_cmd+=("${parallel_args[@]}")
            fi
            pytest_cmd+=("${selection[@]}")
            "${pytest_cmd[@]}"
            return
        fi

        if [[ "${#parallel_args[@]}" -gt 0 ]]; then
            pytest_cmd+=("${parallel_args[@]}")
        fi
        pytest_cmd+=("${selection[@]}")
        "${pytest_cmd[@]}"
    }

    run_requested_tests() {
        local default_path="$1"
        local parallel_mode="${2:-serial}"

        if [[ "${#requested_args[@]}" -gt 0 ]]; then
            run_scoped_pytest "${default_path}" "${parallel_mode}" "${requested_args[@]}"
            return
        fi

        run_scoped_pytest "${default_path}" "${parallel_mode}"
    }

    ensure_demo_partner_runtime() {
        local demo_partner_root="../demo-partner"
        local demo_partner_python="${demo_partner_root}/.venv/bin/python"
        local demo_partner_online_dir="${demo_partner_root}/partners/online"

        if [[ ! -d "${demo_partner_root}" ]]; then
            echo "[ERROR] 未找到兄弟项目 ../demo-partner；demo-leader 的 integration/e2e 受管测试需要它来拉起临时 Partner runtime。" >&2
            exit 1
        fi

        if [[ ! -d "${demo_partner_online_dir}" ]]; then
            echo "[ERROR] 缺少 demo-partner online 目录：${demo_partner_online_dir}" >&2
            exit 1
        fi

        if [[ ! -x "${demo_partner_python}" ]]; then
            echo "[INFO]  准备 demo-partner 受管测试运行时（缺少 ${demo_partner_python}）。"
            (
                cd "${demo_partner_root}"
                just prep sync
            )
        fi

        if [[ ! -x "${demo_partner_python}" ]]; then
            echo "[ERROR] demo-partner Python 运行时仍不可用：${demo_partner_python}" >&2
            exit 1
        fi
    }

    run_test_doctor() {
        local mode="${1:-integration}"

        ensure_demo_partner_runtime
        case "${mode}" in
            integration)
                SKIP_OPENSSL_DOCTOR=1 \
                SKIP_DOTENV_DOCTOR=1 \
                SKIP_LOCAL_PATH_DOCTOR=1 \
                SKIP_SHARED_INFRA_DOCTOR=1 \
                just doctor
                ;;
            e2e)
                SKIP_OPENSSL_DOCTOR=1 \
                SKIP_DOTENV_DOCTOR=1 \
                SKIP_LOCAL_PATH_DOCTOR=1 \
                just doctor
                ;;
            *)
                echo "[ERROR] 未知 test doctor mode: ${mode}" >&2
                exit 2
                ;;
        esac
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            ensure_demo_partner_runtime
            ;;
        unit)
            run_requested_tests tests/unit/
            ;;
        api)
            run_requested_tests tests/api/
            ;;
        coverage)
            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                uv run pytest tests/unit/ "${requested_args[@]}" --cov=leader --cov-report=term-missing --cov-fail-under=70
            else
                uv run pytest tests/unit/ --cov=leader --cov-report=term-missing --cov-fail-under=70
            fi
            ;;
        integration)
            run_test_doctor integration
            run_requested_tests tests/integration/ loadfile
            ;;
        e2e)
            run_test_doctor e2e
            run_requested_tests tests/e2e/
            ;;
        all)
            just test unit
            just test api
            just test integration
            just test e2e
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

package action='wheel' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    requested_args=()

    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    print_help() {
        echo "package 发布物构建："
        echo "  just package wheel"
        echo "      构建在线运行包（demo-leader + acps-cli + acps-sdk wheel）"
        echo "  just package wheel offline"
        echo "      构建包含 Python 运行时依赖 wheelhouse 的离线包"
        echo "  just package wheel offline --pip-platform manylinux2014_x86_64 --pip-platform manylinux_2_28_x86_64 --pip-implementation cp --pip-abi cp314"
        echo "      为指定目标平台命名发布物，并在依赖 wheel 可用时预下载离线 wheels"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        wheel)
            command=(bash scripts/package-wheel-runtime.sh)

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                if [[ "${requested_args[0]}" == "offline" ]]; then
                    command+=(--offline)
                    requested_args=("${requested_args[@]:1}")
                elif [[ "${requested_args[0]}" == "online" ]]; then
                    requested_args=("${requested_args[@]:1}")
                fi
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                command+=("${requested_args[@]}")
            fi

            "${command[@]}"
            ;;
        *)
            echo "[ERROR] 未知 package action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        all)
            just qa fix
            just qa precommit
            ;;
        fmt)
            uv run ruff format .
            ;;
        type)
            uv run mypy leader/
            ;;
        fix)
            uv run ruff format .
            uv run ruff check . --fix
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac
