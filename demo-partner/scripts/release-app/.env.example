# 默认值已对齐同机 stage-infra + release-app + RabbitMQ 拓扑，复制后可直接部署。
# 真实 LLM 参数统一从本文件注入，partners/online/*/config.toml 只保留环境变量名引用。

APP_ENV=production

PARTNERS_IMAGE=acps-demo-partners:latest

INFRA_HOST=host.docker.internal
RABBITMQ_URL=amqps://${INFRA_HOST}:5671/acps?auth=external

REGISTRY_API_BASE_URL=http://${INFRA_HOST}:9000/registry/api
CA_SERVER_URL=http://${INFRA_HOST}:9000/ca-server
DISCOVERY_SERVER_BASE_URL=http://${INFRA_HOST}:9000/discovery/acps-adp-v2

RABBITMQ_HOST=${INFRA_HOST}
RABBITMQ_PORT=5671
RABBITMQ_VHOST=acps
MQ_AUTH_URL=https://${INFRA_HOST}:9007

PARTNER_LLM_FAST_API_KEY=
PARTNER_LLM_FAST_BASE_URL=
PARTNER_LLM_FAST_MODEL=

PARTNER_LLM_DEFAULT_API_KEY=
PARTNER_LLM_DEFAULT_BASE_URL=
PARTNER_LLM_DEFAULT_MODEL=

PARTNER_LLM_PRO_API_KEY=
PARTNER_LLM_PRO_BASE_URL=
PARTNER_LLM_PRO_MODEL=
