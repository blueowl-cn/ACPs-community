# App 基本设置
APP_NAME="Agent Discovery Server"
APP_VERSION="1.0.0"
APP_DESC="基于自然语言请求提供 Agent 发现的 API 服务"
APP_LOG_LEVEL="info"
APP_ROOT_PATH=""

# Uvicorn 启动参数
UVICORN_HOST="0.0.0.0"
UVICORN_PORT=8005
UVICORN_RELOAD=false
UVICORN_LOG_LEVEL="info"

# Database 参数
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_discovery
DATABASE_OUTPUT_SQL=false

# Registry 数据同步参数
DRC_BASE_URL="http://localhost:8001/acps-drc-v1"
DRC_SNAPSHOT_CHUNK_SIZE=10000
DRC_CHANGES_CHUNK_SIZE=1000
DRC_CHANGES_PULL_INTERVAL=600    # 轮询的间隔时间（秒）
# DRC WebHook配置
DRC_WEBHOOK_SECRET=drc_webhook_secret
DRC_WEBHOOK_RECEIVE_URL=http://localhost:8005/admin/drc/webhooks/receive

# DASHSCOPE API key (必填，去官网申请)
DASHSCOPE_API_KEY=your_api_key_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=your_openai_api_endpoint_here
EMBEDDING_MODEL_NAME=text-embedding-3-small

# 转发服务器的完整 URL，如果不配置或留空，则禁用转发功能
FORWARDER_SERVER_URL=http://xxx:xxx/acps-adp-v2

# 请求转发服务器的超时时间（秒）
FORWARDER_SERVER_TIMEOUT=30.0

# 是否启用转发服务器
FORWARDER_SERVER_ENABLED=false

# 转发服务器健康检查间隔（秒）
FORWARDER_HEALTH_CHECK_INTERVAL=600

# 转发服务器请求失败时的重试次数
FORWARDER_REQUEST_RETRIES=0

# 转发服务器失败时是否回退到本地处理
FORWARDER_FALLBACK_TO_LOCAL=true