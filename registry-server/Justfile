        @echo "  just test [action] [args...]"
        @echo "  just qa [action] [args...]"
        @echo "  just infra [action] [args...]"
        @echo "  just doctor"
        @echo "  just package [action] [args...]"
        @echo "  just prep [action] [args...]"
        @echo ""
