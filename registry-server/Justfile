        @echo "  just test bootstrap"
        @echo "  just test"
        @echo "  just qa"

infra action='status' *args:
    @{{dev_infra_script}} {{action}} {{args}}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0
    infra_ok=1
    dotenv_ready=0
    uv_ready=0
    mtls_enabled="true"
    skip_local_mtls_check="${SKIP_LOCAL_MTLS_DOCTOR:-0}"

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    elif ! uv run --no-sync python -c 'import sys; raise SystemExit(0 if (3, 14) <= sys.version_info < (4, 0) else 1)' >"${tmpfile}" 2>&1; then
        echo "[ERROR] .venv Python 版本不满足 pyproject.toml 要求（需要 >=3.14,<4.0）。请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    else
        uv_ready=1
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if ! command -v openssl >/dev/null 2>&1; then
        echo "[ERROR] 未找到 openssl；just prep certs 依赖共享开发 PKI 脚本使用 openssl。" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -f .env ]]; then
        echo "[ERROR] 未找到 .env，请先执行 just prep env。" >&2
        issues=$((issues + 1))
    else
        dotenv_ready=1
    fi

    if [[ "${dotenv_ready}" -eq 1 && "${uv_ready}" -eq 1 ]]; then
        if mtls_enabled_output="$(uv run python -c 'from app.core.config import settings; print("true" if settings.enable_mtls_listener else "false")' 2>"${tmpfile}")"; then
            mtls_enabled="${mtls_enabled_output}"
        else
            echo "[WARN]  无法解析 enable_mtls_listener，按启用 mTLS listener 处理。" >&2
            cat "${tmpfile}" >&2
        fi
    fi

    if [[ "${mtls_enabled}" == "true" ]]; then
        if [[ "${skip_local_mtls_check}" == "1" ]]; then
            echo "[INFO]  跳过本地 mTLS listener 证书检查（SKIP_LOCAL_MTLS_DOCTOR=1）。"
        else
            for cert_path in {{local_mtls_cert_file}} {{local_mtls_key_file}} {{local_mtls_ca_cert_file}} {{local_mtls_probe_cert_file}} {{local_mtls_probe_key_file}}; do
                if [[ ! -f "${cert_path}" ]]; then
                    echo "[ERROR] 本地 mTLS 开发证书缺失：${cert_path}。请先执行 just prep certs。" >&2
                    issues=$((issues + 1))
                fi
            done
        fi
    fi

    if [[ "${SKIP_SHARED_INFRA_DOCTOR:-0}" == "1" ]]; then
        echo "[INFO]  跳过共享 infra 检查（SKIP_SHARED_INFRA_DOCTOR=1）。"
    else
        if [[ ! -x {{dev_infra_script}} ]]; then
            echo "[ERROR] 未找到共享 infra 工具：{{dev_infra_script}}" >&2
            issues=$((issues + 1))
            infra_ok=0
        elif ! just infra doctor >"${tmpfile}" 2>&1; then
            echo "[ERROR] 共享 infra 工具检查失败。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
            infra_ok=0
        fi

        if [[ "${infra_ok}" -eq 1 ]]; then
            if ! status_output="$(just infra status postgres --format=tsv 2>"${tmpfile}")"; then
                echo "[ERROR] 无法读取共享 PostgreSQL 状态。" >&2
                cat "${tmpfile}" >&2
                issues=$((issues + 1))
            elif [[ -z "${status_output}" ]]; then
                echo "[ERROR] 共享 PostgreSQL 状态输出为空。" >&2
                issues=$((issues + 1))
            else
                IFS=$'\t' read -r service _mode state health _ports <<<"${status_output%%$'\n'*}"

                if [[ "${service}" != "postgres" ]]; then
                    echo "[ERROR] 共享 PostgreSQL 状态输出格式异常：${status_output}" >&2
                    issues=$((issues + 1))
                else
                    if [[ "${state}" != "running" ]]; then
                        echo "[ERROR] 共享 PostgreSQL 未运行（state=${state}）。请先执行 just infra up postgres。" >&2
                        issues=$((issues + 1))
                    fi

                    if [[ "${health}" != "healthy" ]]; then
                        echo "[ERROR] 共享 PostgreSQL 未健康（health=${health}）。" >&2
                        issues=$((issues + 1))
                    fi
                fi
            fi
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO]  doctor checks passed for {{project_name}}"

_bootstrap_common:
    @just infra up postgres
    @just prep env
    @just prep sync
    @just prep hooks
    @just prep certs

package action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    requested_args=()

    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    print_help() {
        echo "package 发布物构建："
        echo "  just package wheel"
        echo "      构建在线运行包（应用 wheel + config/alembic/.env.example + requirements-runtime.txt）"
        echo "  just package wheel offline"
        echo "      构建包含 Python 运行时依赖 wheelhouse 的离线包"
        echo "  just package wheel offline --pip-platform manylinux2014_x86_64 --pip-platform manylinux_2_28_x86_64 --pip-implementation cp --pip-abi cp314"
        echo "      为指定目标平台命名发布物，并预下载对应 ABI 的离线 wheels"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        wheel)
            command=(bash scripts/package-wheel-runtime.sh)

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                if [[ "${requested_args[0]}" == "offline" ]]; then
                    command+=(--offline)
                    requested_args=("${requested_args[@]:1}")
                elif [[ "${requested_args[0]}" == "online" ]]; then
                    requested_args=("${requested_args[@]:1}")
                fi
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                command+=("${requested_args[@]}")
            fi
            "${command[@]}"
            ;;
        *)
            echo "[ERROR] 未知 package action: ${action}" >&2
            exit 2
            ;;
    esac

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    print_help() {
        echo "prep 维护动作："
        echo "  just prep env           缺失时根据 .env.example 生成 .env，并刷新敏感字段默认值"
        echo "  just prep sync          执行 uv sync"
        echo "  just prep hooks         安装/更新 pre-commit 与 commit-msg hooks"
        echo "  just prep certs         直接调用共享开发 PKI 签发 registry-server 本地 mTLS 开发证书"
        echo "  just prep migrate [app|test]  对开发/测试数据库执行 alembic upgrade head（默认 app）"
    }

    install_git_hooks() {
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "[WARN]  当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            return
        fi

        uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
        echo "[INFO]  已安装或更新 pre-commit / commit-msg hooks。"
    }

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    # For pre-sync steps: never rely on host python3; reuse .venv if present, otherwise fall back to uv managed Python 3.14.
    run_bootstrap_python() {
        UV_MANAGED_PYTHON=1 uv run --python 3.14 --managed-python --no-project python "$@"
    }

    resolve_test_database_url() {
        load_dotenv

        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        uv run python -c 'from tests.support.constants import DEFAULT_TEST_DATABASE_DSN; print(DEFAULT_TEST_DATABASE_DSN)'
    }

    validate_test_database_url() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" uv run python -c 'import os; from sqlalchemy.engine import make_url; dsn = os.environ["TEST_DATABASE_URL"]; db = make_url(dsn).database; raise SystemExit(0 if db and db != "agent_registry" else 1)'; then
            echo "[ERROR] TEST_DATABASE_URL 必须指向独立测试库，不能指向 agent_registry。" >&2
            exit 1
        fi
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO]  .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                run_bootstrap_python -c 'from functools import reduce; from pathlib import Path; import re, secrets; env_path = Path(".env"); replacements = {"SECRET_KEY": (secrets.token_hex(32), "  # noqa: S105"), "SM4_ENCRYPTION_KEY": (secrets.token_hex(16), ""), "AIC_CRC_SALT": (f"0x{secrets.token_hex(4).upper()}", "")}; content = env_path.read_text(encoding="utf-8"); content = reduce(lambda acc, item: re.sub(rf"^{item[0]}=.*$", f"{item[0]}={item[1][0]}{item[1][1]}", acc, flags=re.MULTILINE), replacements.items(), content); env_path.write_text(content if content.endswith("\n") else content + "\n", encoding="utf-8")'
                echo "[INFO]  已根据 .env.example 生成 .env，并写入新的敏感默认值。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            install_git_hooks
            ;;
        certs)
            if [[ ! -x {{dev_pki_script}} ]]; then
                echo "[ERROR] 未找到共享开发 PKI 脚本：{{dev_pki_script}}" >&2
                exit 1
            fi

            bash {{dev_pki_script}} issue-leaf \
                --ca infra \
                --common-name "registry-server" \
                --usage serverAuth \
                --san "DNS:localhost,DNS:registry-server,DNS:host.docker.internal,IP:127.0.0.1" \
                --cert-out {{local_mtls_cert_file}} \
                --key-out {{local_mtls_key_file}} \
                --relative-to "$PWD"

            bash {{dev_pki_script}} issue-leaf \
                --ca infra \
                --common-name "healthcheck-client" \
                --usage clientAuth \
                --cert-out {{local_mtls_probe_cert_file}} \
                --key-out {{local_mtls_probe_key_file}} \
                --relative-to "$PWD"

            bash {{dev_pki_script}} export-ca \
                --ca bundle \
                --bundle-out {{local_mtls_ca_cert_file}} \
                --relative-to "$PWD"

            for cert_path in {{local_mtls_cert_file}} {{local_mtls_key_file}} {{local_mtls_ca_cert_file}} {{local_mtls_probe_cert_file}} {{local_mtls_probe_key_file}}; do
                if [[ ! -f "${cert_path}" ]]; then
                    echo "[ERROR] 开发证书签发完成后仍缺少文件：${cert_path}" >&2
                    exit 1
                fi
            done
            ;;
        migrate)
            migrate_target="app"
            set -- {{args}}
            if [[ $# -gt 1 ]]; then
                echo "[ERROR] just prep migrate 只接受一个可选目标参数：app 或 test。" >&2
                exit 2
            fi
            if [[ $# -eq 1 ]]; then
                if [[ "$1" != "app" && "$1" != "test" ]]; then
                    echo "[ERROR] just prep migrate 仅支持 app 或 test，当前为：$1" >&2
                    exit 2
                fi
                migrate_target="$1"
            fi

            if [[ "${migrate_target}" == "app" ]]; then
                uv run alembic upgrade head
            else
                test_database_url="$(resolve_test_database_url)"
                validate_test_database_url "${test_database_url}"
                APP_ENV=testing DATABASE_URL="${test_database_url}" TEST_DATABASE_URL="${test_database_url}" uv run alembic upgrade head
            fi
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

app action='start' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    host="{{app_host}}"
    port="{{app_port}}"
    mtls_port="{{mtls_app_port}}"
    pid_file="{{app_pid_file}}"
    log_file="{{app_log_file}}"
    app_module="{{app_module}}"
    mtls_entry_module="{{mtls_entry_module}}"
    mtls_cert_file="{{local_mtls_cert_file}}"
    mtls_key_file="{{local_mtls_key_file}}"
    mtls_ca_cert_file="{{local_mtls_ca_cert_file}}"
    mtls_probe_cert_file="{{local_mtls_probe_cert_file}}"
    mtls_probe_key_file="{{local_mtls_probe_key_file}}"
    mtls_probe_ca_cert_file="{{local_mtls_probe_ca_cert_file}}"
    public_health_url="http://127.0.0.1:${port}/health"
    mtls_health_url="https://127.0.0.1:${mtls_port}/health"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    ensure_log_dir() {
        mkdir -p "$(dirname "${pid_file}")"
    }

    read_pid() {
        if [[ -f "${pid_file}" ]]; then
            tr -d '[:space:]' < "${pid_file}"
        fi
    }

    is_running() {
        local pid="$1"
        [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
    }

    cleanup_stale_pid() {
        local pid
        pid="$(read_pid || true)"
        if [[ -n "${pid}" ]] && ! is_running "${pid}"; then
            rm -f "${pid_file}"
            echo "[WARN]  检测到 stale pid ${pid}，已移除 ${pid_file}。" >&2
        fi
    }

    resolve_mtls_listener_enabled() {
        uv run python -c 'from app.core.config import settings; print("true" if settings.enable_mtls_listener else "false")'
    }

    build_extra_uvicorn_args() {
        if [[ "${#requested_args[@]}" -eq 0 ]]; then
            return
        fi

        printf '%q ' "${requested_args[@]}"
    }

    build_listener_pair_command() {
        local reload_flag="$1"
        local mtls_enabled="$2"
        local extra_uvicorn_args=""
        local app_module_q
        local mtls_entry_module_q
        local host_q
        local port_q
        local mtls_port_q
        local mtls_cert_file_q
        local mtls_key_file_q
        local mtls_ca_cert_file_q

        extra_uvicorn_args="$(build_extra_uvicorn_args)"
        app_module_q="$(printf '%q' "${app_module}")"
        mtls_entry_module_q="$(printf '%q' "${mtls_entry_module}")"
        host_q="$(printf '%q' "${host}")"
        port_q="$(printf '%q' "${port}")"
        mtls_port_q="$(printf '%q' "${mtls_port}")"
        mtls_cert_file_q="$(printf '%q' "${mtls_cert_file}")"
        mtls_key_file_q="$(printf '%q' "${mtls_key_file}")"
        mtls_ca_cert_file_q="$(printf '%q' "${mtls_ca_cert_file}")"

        if [[ "${mtls_enabled}" != "true" ]]; then
            printf '%s\n' \
                'set -eu -o pipefail' \
                'public_pid=""' \
                'cleanup() {' \
                '    if [[ -n "${public_pid}" ]] && kill -0 "${public_pid}" 2>/dev/null; then' \
                '        kill "${public_pid}" 2>/dev/null || true' \
                '    fi' \
                '    if [[ -n "${public_pid}" ]]; then' \
                '        wait "${public_pid}" 2>/dev/null || true' \
                '    fi' \
                '}' \
                'trap cleanup EXIT TERM INT' \
                "uv run uvicorn ${app_module_q} ${reload_flag} --host ${host_q} --port ${port_q}${extra_uvicorn_args:+ ${extra_uvicorn_args}} &" \
                'public_pid=$!' \
                'wait "${public_pid}"' \
                'exit $?'
            return
        fi

        printf '%s\n' \
            'set -eu -o pipefail' \
            'public_pid=""' \
            'mtls_pid=""' \
            'cleanup() {' \
            '    if [[ -n "${public_pid}" ]] && kill -0 "${public_pid}" 2>/dev/null; then' \
            '        kill "${public_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${mtls_pid}" ]] && kill -0 "${mtls_pid}" 2>/dev/null; then' \
            '        kill "${mtls_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${public_pid}" ]]; then' \
            '        wait "${public_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${mtls_pid}" ]]; then' \
            '        wait "${mtls_pid}" 2>/dev/null || true' \
            '    fi' \
            '}' \
            'trap cleanup EXIT TERM INT' \
            "uv run uvicorn ${app_module_q} ${reload_flag} --host ${host_q} --port ${port_q}${extra_uvicorn_args:+ ${extra_uvicorn_args}} &" \
            'public_pid=$!' \
            "REGISTRY_SERVER_MTLS_CERT_FILE=${mtls_cert_file_q} REGISTRY_SERVER_MTLS_KEY_FILE=${mtls_key_file_q} REGISTRY_SERVER_MTLS_CA_CERT_FILE=${mtls_ca_cert_file_q} REGISTRY_SERVER_MTLS_PORT=${mtls_port_q} uv run python -m ${mtls_entry_module_q} &" \
            'mtls_pid=$!' \
            'while kill -0 "${public_pid}" 2>/dev/null && kill -0 "${mtls_pid}" 2>/dev/null; do' \
            '    sleep 1' \
            'done' \
            'if ! kill -0 "${public_pid}" 2>/dev/null; then' \
            '    wait "${public_pid}"' \
            '    exit $?' \
            'fi' \
            'wait "${mtls_pid}"' \
            'exit $?'
    }

    wait_for_health() {
        local pid="$1"
        local attempt

        for attempt in {1..30}; do
            if uv run python -m app.runtime_healthcheck >/dev/null 2>&1; then
                return 0
            fi

            if ! is_running "${pid}"; then
                return 1
            fi

            sleep 1
        done

        return 1
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate app
            ;;
        start)
            just doctor
            ensure_log_dir
            background=1
            if [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "fg" ]]; then
                background=0
                requested_args=("${requested_args[@]:1}")
            elif [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "bg" ]]; then
                background=1
                requested_args=("${requested_args[@]:1}")
            fi

            if [[ "${background}" -eq 1 ]]; then
                cleanup_stale_pid
                existing_pid="$(read_pid || true)"
                if is_running "${existing_pid}"; then
                    echo "[INFO]  {{project_name}} 已在后台运行（pid=${existing_pid}）。"
                    exit 0
                fi

                mtls_enabled="$(resolve_mtls_listener_enabled)"
                command_string="$(build_listener_pair_command "--reload" "${mtls_enabled}")"
                nohup bash -c "${command_string}" >"${log_file}" 2>&1 &
                pid="$!"
                printf '%s\n' "${pid}" > "${pid_file}"

                if wait_for_health "${pid}"; then
                    echo "[INFO]  {{project_name}} 已在后台启动（pid=${pid}）。"
                    echo "[INFO]  日志文件：${log_file}"
                    echo "[INFO]  Public 平面：http://localhost:${port}"
                    if [[ "${mtls_enabled}" == "true" ]]; then
                        echo "[INFO]  mTLS 平面：https://localhost:${mtls_port}"
                    fi
                else
                    echo "[ERROR] {{project_name}} 后台启动失败，请检查日志：${log_file}" >&2
                    if is_running "${pid}"; then
                        kill "${pid}" 2>/dev/null || true
                        wait "${pid}" 2>/dev/null || true
                    fi
                    rm -f "${pid_file}"
                    exit 1
                fi
            else
                mtls_enabled="$(resolve_mtls_listener_enabled)"
                command_string="$(build_listener_pair_command "--reload" "${mtls_enabled}")"
                if [[ "${mtls_enabled}" == "true" ]]; then
                    echo "[INFO]  启动 {{project_name}}（前台，热重载，双 listener）..."
                else
                    echo "[INFO]  启动 {{project_name}}（前台，热重载，public listener）..."
                fi
                echo "[INFO]  OpenAPI 文档：http://localhost:${port}/docs"
                echo "[INFO]  Public 平面健康检查：${public_health_url}"
                if [[ "${mtls_enabled}" == "true" ]]; then
                    echo "[INFO]  mTLS 平面健康检查：${mtls_health_url}"
                fi
                exec bash -c "${command_string}"
            fi
            ;;
        stop)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if ! is_running "${pid}"; then
                rm -f "${pid_file}"
                echo "[INFO]  {{project_name}} 当前没有后台实例。"
                exit 0
            fi

            kill "${pid}" 2>/dev/null || true
            wait "${pid}" 2>/dev/null || true
            rm -f "${pid_file}"
            echo "[INFO]  已停止 {{project_name}} 后台实例（pid=${pid}）。"
            ;;
        status)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if is_running "${pid}"; then
                echo "[INFO]  {{project_name}} 正在运行（pid=${pid}）。"
            else
                echo "[INFO]  {{project_name}} 当前未运行。"
            fi
            ;;
        logs)
            ensure_log_dir
            if [[ ! -f "${log_file}" ]]; then
                echo "[ERROR] 未找到日志文件：${log_file}" >&2
                exit 1
            fi

            if [[ "${args_string}" == "follow" ]]; then
                exec tail -f "${log_file}"
            fi

            tail -n 200 "${log_file}"
            ;;
        restart)
            just app stop
            if [[ -z "${args_string}" ]] || [[ "${args_string}" == "bg" ]]; then
                just app start
            else
                echo "[ERROR] app restart 只管理后台实例；如需前台运行，请直接执行 just app start fg。" >&2
                exit 2
            fi
            ;;
        *)
            echo "[ERROR] 未知 app action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    host="{{test_server_host}}"
    app_module="{{app_module}}"
    mtls_entry_module="{{mtls_entry_module}}"
    mtls_cert_file="{{local_mtls_cert_file}}"
    mtls_key_file="{{local_mtls_key_file}}"
    mtls_ca_cert_file="{{local_mtls_ca_cert_file}}"
    mtls_probe_cert_file="{{local_mtls_probe_cert_file}}"
    mtls_probe_key_file="{{local_mtls_probe_key_file}}"
    mtls_probe_ca_cert_file="{{local_mtls_probe_ca_cert_file}}"
    test_server_pid=""
    test_server_log=""
    test_server_base_url=""
    test_server_mtls_base_url=""

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    # For post-sync steps: run strictly against the project .venv without mutating it.
    run_venv_python() {
        uv run --no-sync python "$@"
    }

    resolve_test_database_url() {
        load_dotenv

        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        run_venv_python -c 'from tests.support.constants import DEFAULT_TEST_DATABASE_DSN; print(DEFAULT_TEST_DATABASE_DSN)'
    }

    validate_test_e2e_base_url() {
        local base_url="$1"

        if ! run_venv_python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); host = parts.hostname or ""; ok = parts.scheme in {"http", "https"} and host in {"127.0.0.1", "localhost"} and parts.port is not None and parts.path in {"", "/"}; raise SystemExit(0 if ok else 1)' "${base_url}"; then
            echo "[ERROR] TEST_E2E_BASE_URL 必须是指向本地临时测试实例的完整 URL，例如：http://127.0.0.1:19123。" >&2
            exit 1
        fi
    }

    find_free_port() {
        run_venv_python -c 'import socket; sock = socket.socket(); sock.bind(("127.0.0.1", 0)); print(sock.getsockname()[1]); sock.close()'
    }

    validate_test_database_url() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" run_venv_python -c 'import os; from sqlalchemy.engine import make_url; dsn = os.environ["TEST_DATABASE_URL"]; db = make_url(dsn).database; raise SystemExit(0 if db and db != "agent_registry" else 1)'; then
            echo "[ERROR] TEST_DATABASE_URL 必须指向独立测试库，不能指向 agent_registry。" >&2
            exit 1
        fi
    }

    check_test_database_connectivity() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" run_venv_python -c 'import os, psycopg; from sqlalchemy.engine import make_url; url = make_url(os.environ["TEST_DATABASE_URL"]); conn = psycopg.connect(host=url.host, port=url.port or 5432, user=url.username, password=url.password, dbname=url.database); cur = conn.cursor(); cur.execute("SELECT 1"); cur.fetchone(); cur.close(); conn.close()' >/dev/null 2>&1; then
            echo "[ERROR] 测试数据库不可连接，请先执行 just test bootstrap 或检查 TEST_DATABASE_URL。" >&2
            exit 1
        fi
    }

    check_test_database_schema_ready() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" run_venv_python -c 'import os, psycopg; from sqlalchemy.engine import make_url; url = make_url(os.environ["TEST_DATABASE_URL"]); conn = psycopg.connect(host=url.host, port=url.port or 5432, user=url.username, password=url.password, dbname=url.database); cur = conn.cursor(); cur.execute("SELECT version_num FROM alembic_version LIMIT 1"); row = cur.fetchone(); cur.close(); conn.close(); raise SystemExit(0 if row and row[0] else 1)' >/dev/null 2>&1; then
            echo "[ERROR] 测试数据库 schema 未准备好，请先执行 just test bootstrap 或 just prep migrate test。" >&2
            exit 1
        fi
    }

    run_test_doctor() {
        local mode="${1:-full}"
        local test_database_url

        case "${mode}" in
            integration)
                SKIP_LOCAL_MTLS_DOCTOR=1 just doctor
                ;;
            full|e2e)
                just doctor
                ;;
            *)
                echo "[ERROR] 未知 test doctor mode: ${mode}" >&2
                exit 2
                ;;
        esac
        test_database_url="$(resolve_test_database_url)"
        validate_test_database_url "${test_database_url}"
        check_test_database_connectivity "${test_database_url}"
        check_test_database_schema_ready "${test_database_url}"
    }

    run_scoped_pytest() {
        local default_path="$1"
        shift
        local selection=("$@")

        if [[ "${#selection[@]}" -eq 0 ]]; then
            uv run pytest "${default_path}"
            return
        fi

        if [[ "${selection[0]}" == -* ]]; then
            uv run pytest "${default_path}" "${selection[@]}"
            return
        fi

        uv run pytest "${selection[@]}"
    }

    run_requested_tests() {
        local default_path="$1"

        if [[ "${#requested_args[@]}" -gt 0 ]]; then
            TEST_E2E_BASE_URL="${test_server_base_url:-${TEST_E2E_BASE_URL:-}}" \
            TEST_E2E_MTLS_BASE_URL="${test_server_mtls_base_url:-${TEST_E2E_MTLS_BASE_URL:-}}" \
            TEST_E2E_MTLS_CLIENT_CERT_FILE="${mtls_probe_cert_file}" \
            TEST_E2E_MTLS_CLIENT_KEY_FILE="${mtls_probe_key_file}" \
            TEST_E2E_MTLS_CA_CERT_FILE="${mtls_probe_ca_cert_file}" \
            run_scoped_pytest "${default_path}" "${requested_args[@]}"
            return
        fi

        TEST_E2E_BASE_URL="${test_server_base_url:-${TEST_E2E_BASE_URL:-}}" \
        TEST_E2E_MTLS_BASE_URL="${test_server_mtls_base_url:-${TEST_E2E_MTLS_BASE_URL:-}}" \
        TEST_E2E_MTLS_CLIENT_CERT_FILE="${mtls_probe_cert_file}" \
        TEST_E2E_MTLS_CLIENT_KEY_FILE="${mtls_probe_key_file}" \
        TEST_E2E_MTLS_CA_CERT_FILE="${mtls_probe_ca_cert_file}" \
        run_scoped_pytest "${default_path}"
    }

    run_coverage_tests() {
        uv run pytest --cov=app --cov-report=term-missing --cov-report=html tests/unit/ tests/integration/
    }

    stop_test_server() {
        if [[ -n "${test_server_pid}" ]] && kill -0 "${test_server_pid}" 2>/dev/null; then
            kill "${test_server_pid}" 2>/dev/null || true
            wait "${test_server_pid}" 2>/dev/null || true
            echo "[INFO]  已停止临时测试实例。"
        fi

        if [[ -n "${test_server_log}" ]] && [[ -f "${test_server_log}" ]]; then
            rm -f "${test_server_log}"
        fi
    }

    wait_for_test_server() {
        local attempt

        for attempt in {1..30}; do
            if curl -fsS "${test_server_base_url}/health" >/dev/null 2>&1 \
                && curl -fsS --cert "${mtls_probe_cert_file}" --key "${mtls_probe_key_file}" --cacert "${mtls_probe_ca_cert_file}" "${test_server_mtls_base_url}/health" >/dev/null 2>&1; then
                return 0
            fi

            if ! kill -0 "${test_server_pid}" 2>/dev/null; then
                echo "[ERROR] 临时测试实例启动失败。" >&2
                cat "${test_server_log}" >&2
                return 1
            fi

            sleep 1
        done

        echo "[ERROR] 等待临时测试实例就绪超时：${test_server_base_url}" >&2
        cat "${test_server_log}" >&2
        return 1
    }

    start_test_server() {
        local test_database_url="$1"
        local command_string
        local test_server_mtls_port
        local test_server_port
        local app_module_q
        local mtls_entry_module_q
        local host_q
        local port_q
        local mtls_port_q
        local mtls_cert_file_q
        local mtls_key_file_q
        local mtls_ca_cert_file_q

        test_server_port="$(find_free_port)"
        test_server_mtls_port="$(find_free_port)"
        test_server_base_url="http://${host}:${test_server_port}"
        test_server_mtls_base_url="https://${host}:${test_server_mtls_port}"
        validate_test_e2e_base_url "${test_server_base_url}"
        validate_test_e2e_base_url "${test_server_mtls_base_url}"
        test_server_log="$(mktemp "${TMPDIR:-/tmp}/registry-server-test.XXXXXX.log")"
        app_module_q="$(printf '%q' "${app_module}")"
        mtls_entry_module_q="$(printf '%q' "${mtls_entry_module}")"
        host_q="$(printf '%q' "${host}")"
        port_q="$(printf '%q' "${test_server_port}")"
        mtls_port_q="$(printf '%q' "${test_server_mtls_port}")"
        mtls_cert_file_q="$(printf '%q' "${mtls_cert_file}")"
        mtls_key_file_q="$(printf '%q' "${mtls_key_file}")"
        mtls_ca_cert_file_q="$(printf '%q' "${mtls_ca_cert_file}")"

        echo "[INFO]  启动临时测试实例：${test_server_base_url}（public） / ${test_server_mtls_base_url}（mtls）"

        command_string="$(printf '%s\n' \
            'set -eu -o pipefail' \
            'public_pid=""' \
            'mtls_pid=""' \
            'cleanup() {' \
            '    if [[ -n "${public_pid}" ]] && kill -0 "${public_pid}" 2>/dev/null; then' \
            '        kill "${public_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${mtls_pid}" ]] && kill -0 "${mtls_pid}" 2>/dev/null; then' \
            '        kill "${mtls_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${public_pid}" ]]; then' \
            '        wait "${public_pid}" 2>/dev/null || true' \
            '    fi' \
            '    if [[ -n "${mtls_pid}" ]]; then' \
            '        wait "${mtls_pid}" 2>/dev/null || true' \
            '    fi' \
            '}' \
            'trap cleanup EXIT TERM INT' \
            "APP_ENV=testing DATABASE_URL=$(printf '%q' "${test_database_url}") TEST_DATABASE_URL=$(printf '%q' "${test_database_url}") uv run uvicorn ${app_module_q} --host ${host_q} --port ${port_q} &" \
            'public_pid=$!' \
            "APP_ENV=testing DATABASE_URL=$(printf '%q' "${test_database_url}") TEST_DATABASE_URL=$(printf '%q' "${test_database_url}") REGISTRY_SERVER_MTLS_CERT_FILE=${mtls_cert_file_q} REGISTRY_SERVER_MTLS_KEY_FILE=${mtls_key_file_q} REGISTRY_SERVER_MTLS_CA_CERT_FILE=${mtls_ca_cert_file_q} REGISTRY_SERVER_MTLS_PORT=${mtls_port_q} uv run python -m ${mtls_entry_module_q} &" \
            'mtls_pid=$!' \
            'while kill -0 "${public_pid}" 2>/dev/null && kill -0 "${mtls_pid}" 2>/dev/null; do' \
            '    sleep 1' \
            'done' \
            'if ! kill -0 "${public_pid}" 2>/dev/null; then' \
            '    wait "${public_pid}"' \
            '    exit $?' \
            'fi' \
            'wait "${mtls_pid}"' \
            'exit $?')"

        bash -c "${command_string}" >"${test_server_log}" 2>&1 &

        test_server_pid="$!"
        wait_for_test_server
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate test
            echo "[INFO]  测试环境准备完成。"
            ;;
        unit)
            run_requested_tests tests/unit/
            ;;
        integration)
            run_test_doctor integration
            run_requested_tests tests/integration/
            ;;
        e2e)
            run_test_doctor e2e
            test_database_url="$(resolve_test_database_url)"
            trap stop_test_server EXIT
            start_test_server "${test_database_url}"
            run_requested_tests tests/e2e/
            ;;
        coverage)
            run_test_doctor integration
            run_coverage_tests
            ;;
        all)
            just test unit
            just test integration
            just test e2e
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        all)
            just qa fix
            just qa precommit
            ;;
        lint)
            uv run ruff format --check .
            uv run ruff check .
            ;;
        fmt)
            uv run ruff format .
            ;;
        fix)
            uv run ruff format .
            uv run ruff check . --fix
            ;;
        type-app)
            uv run mypy --config-file pyproject.toml app
            ;;
        type-tests)
            uv run mypy --config-file pyproject.toml tests
            ;;
        security)
            uv run pre-commit run bandit --all-files
            ;;
        audit)
            tmpfile="$(mktemp)"
            trap 'rm -f "${tmpfile}"' EXIT
            uv export --format requirements.txt --all-groups --no-hashes --no-header --no-emit-project --prune pip-audit --prune pip-api --prune pip --output-file "${tmpfile}"
            uv run pip-audit -r "${tmpfile}" --progress-spinner off
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        full)
            just qa lint
            just qa type-app
            just qa type-tests
            just qa security
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac
