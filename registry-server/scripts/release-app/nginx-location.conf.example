# registry-server 路由片段示例
#
# 用法：将本文件内容合并到宿主机 Nginx 配置（http {} 块中，server {} 块之外）。
#
# 注意：limit_conn_zone 和 limit_req_zone 指令须在 http {} 块中声明（如已在全局配置中
# 声明过同名 zone，可删除下面两行，确保 zone 名称与下方 server {} 内引用一致）。

limit_conn_zone $binary_remote_addr zone=registry_conn_limit:10m;
limit_req_zone  $binary_remote_addr zone=registry_req_limit:10m rate=30r/s;

location = /registry {
    return 301 /registry/;
}

location = /registry/health {
    rewrite ^/registry(/.*)$ $1 break;
    proxy_pass http://registry-server-blue:9001;
}

location ~ ^/registry/(ready|metrics)$ {
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    allow 127.0.0.1;
    allow ::1;
    allow fc00::/7;
    allow fe80::/10;
    deny all;

    rewrite ^/registry(/.*)$ $1 break;
    proxy_pass http://registry-server-blue:9001;
}

location /registry/ {
    limit_conn registry_conn_limit 50;
    limit_req zone=registry_req_limit burst=60 nodelay;

    proxy_pass http://registry-server-blue:9001/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /registry;
    proxy_set_header X-Request-ID $request_id;
}
