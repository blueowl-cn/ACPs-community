# 共享基础设施模式下的应用环境变量
# 仅包含敏感/部署专用配置，非敏感业务参数请修改 config/ 下的 TOML 文件

# ── 部署路径 ──

# 共享网关中的一级路径前缀（不带前导 /）
APP_PATH_PREFIX=registry

# FastAPI 对外暴露的根路径，需与 APP_PATH_PREFIX 一致
ROOT_PATH=/registry

# 冒烟测试访问地址
APP_BASE_URL=http://localhost:9000/registry

# ── 应用环境 ──
APP_ENV=production

# 宿主机证书目录（发布约定：整个目录只读挂载到容器内 /certs）
# `9002` 关闭时该目录可先为空目录；启用 `9002` 前再由外部 provisioner 填充证书材料。
REGISTRY_CERTS_HOST_DIR=/srv/acps/registry-server/certs

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://registry:registry@stage-postgres:5432/agent_registry

# ── 安全密钥 ──

# 同机验证场景下，若保留占位值，deploy.sh 会在首次部署时自动生成随机 SECRET_KEY 并写回 .env。
# 正式环境建议在部署前显式设置为受控密钥。
SECRET_KEY=change-me-to-a-random-secret  # noqa: S105

# SM4 对称加密密钥（32 位十六进制，128-bit）
SM4_ENCRYPTION_KEY=0123456789abcdeffedcba9876543210

# AIC CRC 盐，十六进制，不小于两字节，一旦设置不可更改
# 同机验证场景下，若保留占位值，deploy.sh 会自动生成随机十六进制盐并写回 .env。
AIC_CRC_SALT=0xAAAAAAAA

# ── 部署路径 ──

# 文件上传存储路径
UPLOAD_BASE_PATH=/data/uploads

# CA Server 地址（用于 ATR 证书吊销通知）
# 默认对接同机 stage-infra + ca-server release-app。
CA_SERVER_BASE_URL=http://stage-nginx:9000/ca-server

# registry-server internal API 的 Bearer 服务令牌（需与 ca-server 的 REGISTRY_SERVER_INTERNAL_API_TOKEN 一致）
REGISTRY_SERVER_INTERNAL_API_TOKEN=change-me-registry-server-internal-api-token

# SMTP / 邮件发送（敏感，建议通过 .env 提供；留空则按 config/*.toml 回退）
SMTP_SERVER=
SMTP_PORT=
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# 是否在容器内启动 `9002` mTLS listener。
# 默认为 false，先完成 public-plane bootstrap；证书引导完成后再切换为 true。
REGISTRY_SERVER_ENABLE_MTLS_LISTENER=false

# `9002` 对外发布主机与端口；供部署层、证书 SAN / endpoint 模板与可观测性脚本使用。
REGISTRY_SERVER_MTLS_PUBLIC_HOST=localhost
REGISTRY_SERVER_MTLS_PORT=9002

# mTLS listener（`9002`）证书材料；供 `app.main_mtls` 使用。
# 这里配置的是服务端视角的材料：`9002` 自己的证书/私钥，以及它用来校验“客户端证书链”的 trust anchor。
# `REGISTRY_SERVER_MTLS_CA_CERT_FILE` 不是客户端校验 `9002` 服务端证书时使用的 CA 文件；客户端侧应使用自己的
# verify/CA 配置（例如 `acps-cli.toml` 里的 `registry.mtls_server_ca_file`）。
# 本地联调若客户端本体证书由 intermediate `ca.crt` 签发，这里仍应使用 `root-ca.crt`，或至少使用包含 root 的
# CA bundle；不要只配 intermediate `ca.crt`。
REGISTRY_SERVER_MTLS_CERT_FILE=/certs/server.pem
REGISTRY_SERVER_MTLS_KEY_FILE=/certs/server.key
REGISTRY_SERVER_MTLS_CA_CERT_FILE=/certs/trust-bundle.pem

# `9002` 健康探针 / 冒烟测试客户端证书；仅在部署层与 smoke 使用，不参与服务端启动。
REGISTRY_SERVER_MTLS_PROBE_CERT_FILE=/certs/probe-client.pem
REGISTRY_SERVER_MTLS_PROBE_KEY_FILE=/certs/probe-client.key
