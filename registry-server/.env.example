# Example environment variables - Copy to .env and modify
# 仅包含敏感/部署专用配置，非敏感业务参数请修改 config/ 下的 TOML 文件

# ── 应用环境 ──
# 注意：APP_ENV 决定加载哪个 config/*.toml 覆盖文件，必须在 TOML 加载之前确定，
# 因此只能通过环境变量注入，无法在 TOML 中定义。
APP_ENV=development  # development | testing | production

# ── 数据库 ──

# 应用连接串
DATABASE_URL=postgresql+asyncpg://registry:registry@localhost:5432/agent_registry

# ── 安全密钥 ──

# JWT 签名密钥（`just prep env` 会为新生成的 .env 自动写入随机值）
SECRET_KEY=change-me-to-a-random-secret  # noqa: S105

# SM4 对称加密密钥（32 位十六进制，128-bit；`just prep env` 会自动改写）
SM4_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# AIC CRC 盐，十六进制，不小于两字节，一旦设置不可更改；`just prep env` 会自动改写
AIC_CRC_SALT=0xAAAAAAAA

# registry-server internal API 的 Bearer 服务令牌（需与 ca-server 的 REGISTRY_SERVER_INTERNAL_API_TOKEN 一致；默认示例值可直接用于本地联调）
REGISTRY_SERVER_INTERNAL_API_TOKEN=local-registry-server-internal-api-token

# SMTP / 邮件发送（敏感，建议通过 .env 提供；留空则按 config/*.toml 回退）
SMTP_SERVER=
SMTP_PORT=
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# ── 本地开发 / 测试 mTLS listener ──

# `just prep certs` 会通过共享开发 PKI 将以下文件同步到项目内 `certs/`，
# `just app` / `just test e2e` 会显式把它们注入 `app.main_mtls`。
# 下面三项都是 `9002` 服务端自己的 TLS/mTLS 材料：
# - `REGISTRY_SERVER_MTLS_CERT_FILE` / `REGISTRY_SERVER_MTLS_KEY_FILE`：`9002` 对外呈现的服务端证书与私钥。
# - `REGISTRY_SERVER_MTLS_CA_CERT_FILE`：`9002` 用来校验“客户端证书链”的 trust anchor。
#   它不是调用方拿来校验 `9002` 服务端证书的 CA 文件；客户端侧应使用自己的 verify/CA 配置
#   （例如 `acps-cli.toml` 里的 `registry.mtls_server_ca_file`）。
# 本地联调若客户端本体证书由 intermediate `ca.crt` 签发，这里仍应指向 `root-ca.crt`，或至少使用
# 包含 root 的 CA bundle；不要只填 intermediate `ca.crt`，否则 `9002` 可能在 mTLS 握手阶段拒绝客户端。
REGISTRY_SERVER_MTLS_CERT_FILE=certs/server.pem
REGISTRY_SERVER_MTLS_KEY_FILE=certs/server.key
REGISTRY_SERVER_MTLS_CA_CERT_FILE=certs/trust-bundle.pem

# 本地健康检查 / 黑盒 E2E 共用的 mTLS client 证书。
REGISTRY_SERVER_MTLS_HEALTHCHECK_CERT_FILE=certs/client.pem
REGISTRY_SERVER_MTLS_HEALTHCHECK_KEY_FILE=certs/client.key
REGISTRY_SERVER_MTLS_HEALTHCHECK_CA_CERT_FILE=certs/trust-bundle.pem

# ── 测试专用（pytest / just test 使用，不用于生产部署） ──

# 测试数据库连接串；pytest 与 Just 测试工作流会读取此变量
TEST_DATABASE_URL=postgresql+asyncpg://registry:registry@localhost:5432/agent_registry_test

# 黑盒 E2E 目标服务地址与 mTLS client 证书由 just test e2e 在运行时随机生成并临时注入；不在 .env 中固定定义
