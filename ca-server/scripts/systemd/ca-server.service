[Unit]
Description=ACPs CA Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Default deployment root. Adjust both paths if you install elsewhere.
WorkingDirectory=/opt/ca-server
ExecStart=/opt/ca-server/.venv/bin/python -m app.main
Environment=PYTHONUNBUFFERED=1
SyslogIdentifier=ca-server
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
KillSignal=SIGTERM

# Uncomment after creating a dedicated service account.
# User=ca-server
# Group=ca-server

# The application loads .env from WorkingDirectory via pydantic-settings,
# so this unit intentionally does not use EnvironmentFile=.

[Install]
WantedBy=multi-user.target