# 共享基础设施模式下的敏感 / 部署专用环境变量

# 应用环境
APP_ENV=production

# 共享网关中的一级路径前缀（不带前导 /）
APP_PATH_PREFIX=ca-server

# FastAPI 对外暴露的根路径，需与 APP_PATH_PREFIX 一致
ROOT_PATH=/ca-server

# 冒烟测试访问地址
APP_BASE_URL=http://localhost:9000/ca-server

# 数据库连接
DATABASE_URL=postgresql://ca:ca@stage-postgres:5432/agent_ca

# CA 根证书挂载路径
CA_CERT_PATH=/app/certs/ca.crt
CA_KEY_PATH=/app/certs/ca.key

# ACME / 外部服务配置
# 默认对接同机 stage-infra 网关 + registry-server/ca-server release-app。
ACME_DIRECTORY_URL=http://stage-nginx:9000/ca-server/acps-atr-v2/acme
REGISTRY_SERVER_URL=http://stage-nginx:9000/registry/acps-atr-v2
REGISTRY_SERVER_TIMEOUT=10
REGISTRY_SERVER_MOCK=false

# 外部服务认证（敏感）
REGISTRY_SERVER_INTERNAL_API_TOKEN=