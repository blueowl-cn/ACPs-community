location = /ca-server/acps-atr-v2/ca/trust-bundle {
    rewrite ^/ca-server(/.*)$ $1 break;
    proxy_pass http://ca-server-blue:9003;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location ^~ /ca-server/acps-atr-v2/acme {
    proxy_pass http://ca-server-blue:9003/acps-atr-v2/acme;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location ^~ /ca-server/acps-atr-v2/crl {
    proxy_pass http://ca-server-blue:9003/acps-atr-v2/crl;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location ^~ /ca-server/acps-atr-v2/ocsp {
    proxy_pass http://ca-server-blue:9003/acps-atr-v2/ocsp;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location ^~ /ca-server/acps-atr-v2/ca/retrieve/ {
    proxy_pass http://ca-server-blue:9003/acps-atr-v2/ca/retrieve/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location = /ca-server/acps-atr-v2/ca/revoke-notify {
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    allow 127.0.0.1;
    allow ::1;
    allow fc00::/7;
    allow fe80::/10;
    deny all;

    rewrite ^/ca-server(/.*)$ $1 break;
    proxy_pass http://ca-server-blue:9003;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location ^~ /ca-server/admin/certificates {
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    allow 127.0.0.1;
    allow ::1;
    allow fc00::/7;
    allow fe80::/10;
    deny all;

    proxy_pass http://ca-server-blue:9003/admin/certificates;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}

location /ca-server/ {
    return 404;
}
    proxy_pass http://ca-server-blue:9003/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Prefix /ca-server;
    proxy_set_header X-Request-ID $request_id;
}
