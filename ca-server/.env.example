# Example environment variables - Copy to .env and modify
# 根模板尽量只保留敏感项，以及 APP_ENV 这类必须先于 TOML 加载生效的启动参数。
# 非敏感业务参数请修改 config/ 下的 TOML 文件；如部署系统必须用环境变量覆盖，可按对应变量名单独注入。

# ── 应用环境 ──
# 注意：APP_ENV 决定加载哪个 config/*.toml 覆盖文件，必须在 TOML 加载之前确定，
# 因此只能通过环境变量注入，无法在 TOML 中定义。
APP_ENV=development  # development | testing | production

# ── 数据库 ──

# 应用连接串（共享 dev-infra PostgreSQL）
DATABASE_URL=postgresql://ca:ca@localhost:5432/agent_ca

# ── 外部服务认证 / 受保护端点 ──

# Registry Server internal API 服务令牌；与 registry-server 保持一致
REGISTRY_SERVER_INTERNAL_API_TOKEN=local-registry-server-internal-api-token

# 可选：为 CA internal 端点单独设置 Bearer token；留空时 internal 端点仍可复用 REGISTRY_SERVER_INTERNAL_API_TOKEN
CA_SERVER_INTERNAL_API_TOKEN=

# admin 管理端点 Bearer token；启用管理接口时必须显式设置
CA_SERVER_ADMIN_API_TOKEN=

# ── 测试专用（pytest / just test 使用，不用于生产部署） ──

# 测试数据库连接串；pytest 与 Just 测试工作流会读取此变量
TEST_DATABASE_URL=postgresql://ca:ca@localhost:5432/agent_ca_test

# 黑盒 E2E 目标服务地址由 just test e2e 在运行时随机生成并临时注入；不在 .env 中固定定义
