set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

project_name := "ca-server"
dev_infra_script := "../acps-infra/dev-infra/dev-infra.sh"
dev_pki_script := "../acps-infra/dev-infra/dev-cert.sh"
app_module := "app.main:app"
app_host := "0.0.0.0"
app_port := "9003"
app_pid_file := "logs/ca-server.pid"
app_log_file := "logs/ca-server.log"
test_server_host := "127.0.0.1"
default_test_database_url := "postgresql://ca:ca@localhost:5432/agent_ca_test"

default:
    @just help

help:
        @echo "ca-server Just 命令"
        @echo ""
        @echo "用法："
        @echo "  just app [action] [args...]"
        @echo "  just test [action] [args...]"
        @echo "  just qa [action] [args...]"
        @echo "  just package [action] [args...]"
        @echo "  just infra [action] [args...]"
        @echo "  just doctor"
        @echo "  just prep [action] [args...]"
        @echo ""
        @echo "app：本地应用生命周期"
        @echo "  bootstrap        建立开发环境（infra up + prep env + prep sync + prep hooks + prep certs + prep migrate app）"
        @echo "  start            后台启动服务（默认动作），日志写入 logs/ca-server.log"
        @echo "  start bg         显式后台启动服务"
        @echo "  start fg         前台启动服务，占用当前 console"
        @echo "  stop             停止后台实例"
        @echo "  status           查看后台实例状态"
        @echo "  logs             查看后台日志末尾 200 行"
        @echo "  logs follow      持续跟随后台日志"
        @echo "  restart          重启受管后台实例"
        @echo ""
        @echo "test：测试入口"
        @echo "  bootstrap        建立测试环境（infra up + prep env + prep sync + prep hooks + prep certs + prep migrate test）"
        @echo "  unit             运行单元测试；支持透传 pytest 参数"
        @echo "  coverage         运行单元测试覆盖率门禁（fail-under=70）"
        @echo "  integration      执行测试环境只读检查后运行集成测试"
        @echo "  e2e              执行测试环境只读检查，拉起临时测试实例并运行黑盒 E2E"
        @echo "  all              依次执行 unit -> integration -> e2e"
        @echo ""
        @echo "qa：代码质量入口"
        @echo "  fmt              执行 ruff format ."
        @echo "  fix              执行 format + ruff check --fix"
        @echo "  precommit        执行 pre-commit run --all-files"
        @echo "  audit            执行 pip-audit 依赖漏洞检查"
        @echo "  all              依次执行 fix -> precommit -> audit"
        @echo ""
        @echo "infra：共享依赖管理"
        @echo "  status [service...] [--format=tsv]   查看共享依赖状态"
        @echo "  up [service...]                      启动共享依赖，默认 postgres"
        @echo "  down                                 停止共享依赖"
        @echo "  wait [service...]                    等待共享依赖就绪"
        @echo "  logs [service...] [--follow]         查看共享依赖日志"
        @echo "  reset [service...] [--volumes --yes] 修复性重建共享依赖"
        @echo "  doctor                               检查共享 infra 环境"
        @echo ""
        @echo "doctor：只读环境检查"
        @echo "  检查 uv / .venv Python / just / .env / uv sync 状态 / 证书文件 / dev-infra / PostgreSQL 健康状态"
        @echo ""
        @echo "prep：维护与局部修复动作"
        @echo "  env      缺失时根据 .env.example 生成 .env"
        @echo "  sync     执行 uv sync"
        @echo "  hooks    安装/更新 pre-commit 与 commit-msg hooks"
        @echo "  certs    检查并通过 acps-infra/dev-cert 导出本地开发业务中间 CA 套件（ca.crt/key、ca-chain.pem、trust-bundle.pem）"
        @echo "  migrate [app|test]  对开发/测试数据库执行 alembic upgrade head"
        @echo ""
        @echo "package：原生 wheel 运行包构建"
        @echo "  wheel                                      构建在线运行包（应用 wheel + config/alembic/.env.example）"
        @echo "  wheel offline                              构建包含 Python 运行时依赖 wheelhouse 的离线包"
        @echo "  wheel offline --pip-platform <tag> ...     按指定平台命名发布物并下载离线 wheels"
        @echo "  透传选项：--python-version 3.14 --pip-platform <tag> --pip-implementation cp --pip-abi cp314"
        @echo ""
        @echo "常用示例："
        @echo "  just app bootstrap"
        @echo "  just app start"
        @echo "  just app stop"
        @echo "  just package wheel"
        @echo "  just package wheel offline"
        @echo "  just test bootstrap"
        @echo "  just test"
        @echo "  just qa"

infra action='status' *args:
    @{{dev_infra_script}} {{action}} {{args}}

doctor:
    #!/usr/bin/env bash
    set -eu -o pipefail
    tmpfile="$(mktemp)"
    trap 'rm -f "${tmpfile}"' EXIT
    issues=0
    infra_ok=1
    uv_ready=0
    skip_database_url_check="${SKIP_DATABASE_URL_DOCTOR:-0}"

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    resolve_path() {
        local path="$1"

        if [[ "${path}" = /* ]]; then
            printf '%s\n' "${path}"
        else
            printf '%s\n' "$PWD/${path}"
        fi
    }

    validate_database_url_value() {
        local variable_name="$1"
        local database_url="$2"

        if [[ -z "${database_url}" ]]; then
            echo "[ERROR] ${variable_name} 未配置，请检查 .env 文件。" >&2
            issues=$((issues + 1))
            return
        fi

        if ! uv run --no-sync python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); ok = bool(parts.scheme and parts.username and parts.password not in (None, "") and parts.hostname and parts.path and parts.path != "/"); raise SystemExit(0 if ok else 1)' "${database_url}"; then
            echo "[ERROR] ${variable_name} 配置不完整，请参考 .env.example 使用带用户名、密码、主机和数据库名的完整 URL。" >&2
            issues=$((issues + 1))
        fi
    }

    if ! command -v uv >/dev/null 2>&1; then
        echo "[ERROR] 未找到 uv，请先安装 uv。" >&2
        issues=$((issues + 1))
    elif ! uv sync --check --locked >"${tmpfile}" 2>&1; then
        echo "[ERROR] Python 环境未同步或缺失，请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    elif ! uv run --no-sync python -c 'import sys; raise SystemExit(0 if (3, 14) <= sys.version_info < (4, 0) else 1)' >"${tmpfile}" 2>&1; then
        echo "[ERROR] .venv Python 版本不满足 pyproject.toml 要求（需要 >=3.14,<4.0）。请先执行 just prep sync。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
    else
        uv_ready=1
    fi

    if ! command -v just >/dev/null 2>&1; then
        echo "[ERROR] 未找到 just，请先安装 just。" >&2
        issues=$((issues + 1))
    fi

    if [[ ! -f .env ]]; then
        echo "[ERROR] 未找到 .env，请先执行 just prep env。" >&2
        issues=$((issues + 1))
    else
        load_dotenv
        if [[ "${skip_database_url_check}" == "1" ]]; then
            echo "[INFO]  跳过 DATABASE_URL 检查（SKIP_DATABASE_URL_DOCTOR=1）。"
        elif [[ "${uv_ready}" -eq 1 ]]; then
            validate_database_url_value "DATABASE_URL" "${DATABASE_URL:-}"
        fi

        cert_path="$(resolve_path "${CA_CERT_PATH:-certs/ca.crt}")"
        key_path="$(resolve_path "${CA_KEY_PATH:-certs/ca.key}")"
        chain_path="$(resolve_path "${CA_CHAIN_PATH:-certs/ca-chain.pem}")"
        bundle_path="$(resolve_path "${TRUST_BUNDLE_PATH:-certs/trust-bundle.pem}")"

        if [[ ! -f "${cert_path}" ]]; then
            echo "[ERROR] 未找到 CA 证书文件：${cert_path}。请先执行 just prep certs（委托 acps-infra/dev-infra/dev-cert.sh）或手动放置证书。" >&2
            issues=$((issues + 1))
        fi

        if [[ ! -f "${key_path}" ]]; then
            echo "[ERROR] 未找到 CA 私钥文件：${key_path}。请先执行 just prep certs（委托 acps-infra/dev-infra/dev-cert.sh）或手动放置私钥。" >&2
            issues=$((issues + 1))
        fi

        if [[ ! -f "${chain_path}" ]]; then
            echo "[ERROR] 未找到 CA 证书链文件：${chain_path}。请先执行 just prep certs 从共享开发 PKI 同步完整证书套件。" >&2
            issues=$((issues + 1))
        fi

        if [[ ! -f "${bundle_path}" ]]; then
            echo "[ERROR] 未找到 Trust Bundle 文件：${bundle_path}。请先执行 just prep certs 从共享开发 PKI 同步完整证书套件。" >&2
            issues=$((issues + 1))
        fi
    fi

    if [[ ! -x {{dev_infra_script}} ]]; then
        echo "[ERROR] 未找到共享 infra 工具：{{dev_infra_script}}" >&2
        issues=$((issues + 1))
        infra_ok=0
    elif ! just infra doctor >"${tmpfile}" 2>&1; then
        echo "[ERROR] 共享 infra 工具检查失败。" >&2
        cat "${tmpfile}" >&2
        issues=$((issues + 1))
        infra_ok=0
    fi

    if [[ "${infra_ok}" -eq 1 ]]; then
        if ! status_output="$(just infra status postgres --format=tsv 2>"${tmpfile}")"; then
            echo "[ERROR] 无法读取共享 PostgreSQL 状态。" >&2
            cat "${tmpfile}" >&2
            issues=$((issues + 1))
        elif [[ -z "${status_output}" ]]; then
            echo "[ERROR] 共享 PostgreSQL 状态输出为空。" >&2
            issues=$((issues + 1))
        else
            IFS=$'\t' read -r service _mode state health _ports <<<"${status_output%%$'\n'*}"

            if [[ "${service}" != "postgres" ]]; then
                echo "[ERROR] 共享 PostgreSQL 状态输出格式异常：${status_output}" >&2
                issues=$((issues + 1))
            else
                if [[ "${state}" != "running" ]]; then
                    echo "[ERROR] 共享 PostgreSQL 未运行（state=${state}）。请先执行 just infra up postgres。" >&2
                    issues=$((issues + 1))
                fi

                if [[ "${health}" != "healthy" ]]; then
                    echo "[ERROR] 共享 PostgreSQL 未健康（health=${health}）。" >&2
                    issues=$((issues + 1))
                fi
            fi
        fi
    fi

    if [[ "${issues}" -gt 0 ]]; then
        exit 1
    fi

    echo "[INFO]  doctor checks passed for {{project_name}}"

_bootstrap_common:
    @just infra up postgres
    @just prep env
    @just prep sync
    @just prep hooks
    @just prep certs

package action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    requested_args=()

    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    print_help() {
        echo "package 发布物构建："
        echo "  just package wheel"
        echo "      构建在线运行包（应用 wheel + config/alembic/.env.example + requirements-runtime.txt）"
        echo "  just package wheel offline"
        echo "      构建包含 Python 运行时依赖 wheelhouse 的离线包"
        echo "  just package wheel offline --pip-platform manylinux2014_x86_64 --pip-platform manylinux_2_28_x86_64 --pip-implementation cp --pip-abi cp314"
        echo "      为指定目标平台命名发布物，并在依赖 wheel 可用时预下载离线 wheels"
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        wheel)
            command=(bash scripts/package-wheel-runtime.sh)

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                if [[ "${requested_args[0]}" == "offline" ]]; then
                    command+=(--offline)
                    requested_args=("${requested_args[@]:1}")
                elif [[ "${requested_args[0]}" == "online" ]]; then
                    requested_args=("${requested_args[@]:1}")
                fi
            fi

            if [[ "${#requested_args[@]}" -gt 0 ]]; then
                command+=("${requested_args[@]}")
            fi
            "${command[@]}"
            ;;
        *)
            echo "[ERROR] 未知 package action: ${action}" >&2
            exit 2
            ;;
    esac

prep action='help' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    print_help() {
        echo "prep 维护动作："
        echo "  just prep env           缺失时根据 .env.example 生成 .env"
        echo "  just prep sync          执行 uv sync"
        echo "  just prep hooks         安装/更新 pre-commit 与 commit-msg hooks"
        echo "  just prep certs         检查并委托 acps-infra/dev-infra/dev-cert.sh 导出开发业务中间 CA 套件"
        echo "  just prep migrate [app|test]  对开发/测试数据库执行 alembic upgrade head（默认 app）"
    }

    install_git_hooks() {
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "[WARN]  当前目录不是 Git 仓库，跳过 Git hooks 安装。"
            return
        fi

        uv run pre-commit install --hook-type pre-commit --hook-type commit-msg
        echo "[INFO]  已安装或更新 pre-commit / commit-msg hooks。"
    }

    ensure_ca_material() {
        load_dotenv

        local ca_cert_path ca_key_path ca_chain_path trust_bundle_path certs_dir dev_pki_script

        ca_cert_path="${CA_CERT_PATH:-certs/ca.crt}"
        ca_key_path="${CA_KEY_PATH:-certs/ca.key}"
        ca_chain_path="${CA_CHAIN_PATH:-certs/ca-chain.pem}"
        trust_bundle_path="${TRUST_BUNDLE_PATH:-certs/trust-bundle.pem}"
        dev_pki_script="{{dev_pki_script}}"

        # 相对路径转绝对路径
        [[ "${ca_cert_path}"    != /* ]] && ca_cert_path="$PWD/${ca_cert_path}"
        [[ "${ca_key_path}"     != /* ]] && ca_key_path="$PWD/${ca_key_path}"
        [[ "${ca_chain_path}"   != /* ]] && ca_chain_path="$PWD/${ca_chain_path}"
        [[ "${trust_bundle_path}" != /* ]] && trust_bundle_path="$PWD/${trust_bundle_path}"

        certs_dir="$(dirname "${ca_cert_path}")"

        local -a all_files=(
            "${ca_cert_path}"
            "${ca_key_path}"
            "${ca_chain_path}"
            "${trust_bundle_path}"
        )

        local existing=0
        for f in "${all_files[@]}"; do
            [[ -f "${f}" ]] && existing=$((existing + 1))
        done

        if [[ "${existing}" -eq 4 ]]; then
            echo "[INFO]  证书套件已完整存在（4/4），跳过同步。"
            for f in "${all_files[@]}"; do
                echo "[INFO]    ${f}"
            done
            return
        fi

        if [[ "${existing}" -gt 0 ]]; then
            echo "[ERROR] 证书套件不完整（${existing}/4 个文件存在），无法继续。" >&2
            echo "[ERROR] 请先清理 ${certs_dir}/ 中的旧证书文件，再重新执行 just prep certs。" >&2
            echo "[ERROR] 当前存在的文件：" >&2
            for f in "${all_files[@]}"; do
                [[ -f "${f}" ]] && echo "[ERROR]   ${f}" >&2
            done
            exit 1
        fi

        if [[ ! -x "${dev_pki_script}" ]]; then
            echo "[ERROR] 未找到共享开发 PKI 脚本：${dev_pki_script}" >&2
            exit 1
        fi

        echo "[INFO]  开始通过共享开发 PKI 导出业务中间 CA 套件（4 个持久化文件）..."
        bash "${dev_pki_script}" export-ca \
            --ca agent \
            --cert-out "${CA_CERT_PATH:-certs/ca.crt}" \
            --key-out "${CA_KEY_PATH:-certs/ca.key}" \
            --chain-out "${CA_CHAIN_PATH:-certs/ca-chain.pem}" \
            --bundle-out "${TRUST_BUNDLE_PATH:-certs/trust-bundle.pem}" \
            --relative-to "$PWD"

        echo "[INFO]  本地开发 CA 套件已同步（4/4）："
        for f in "${all_files[@]}"; do
            echo "[INFO]    ${f}"
        done
    }

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    run_venv_python() {
        uv run --no-sync python "$@"
    }

    validate_database_url_value() {
        local variable_name="$1"
        local database_url="$2"

        if [[ -z "${database_url}" ]]; then
            echo "[ERROR] ${variable_name} 未配置，请检查 .env 文件。" >&2
            exit 1
        fi

        if ! run_venv_python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); ok = bool(parts.scheme and parts.username and parts.password not in (None, "") and parts.hostname and parts.path and parts.path != "/"); raise SystemExit(0 if ok else 1)' "${database_url}"; then
            echo "[ERROR] ${variable_name} 配置不完整，请参考 .env.example 使用带用户名、密码、主机和数据库名的完整 URL。" >&2
            exit 1
        fi
    }

    get_database_name_from_url() {
        run_venv_python -c 'from urllib.parse import urlsplit; import re, sys; database_name = urlsplit(sys.argv[1]).path.lstrip("/"); valid = bool(database_name) and re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", database_name) is not None; sys.stdout.write(database_name + "\n") if valid else sys.exit(1)' "$1"
    }

    resolve_test_database_url() {
        load_dotenv

        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        printf '%s\n' "{{default_test_database_url}}"
    }

    resolve_development_database_url() {
        load_dotenv
        printf '%s\n' "${DATABASE_URL:-}"
    }

    validate_test_database_url() {
        local test_database_url="$1"
        local development_database_url="$2"
        local test_database_name

        validate_database_url_value "TEST_DATABASE_URL" "${test_database_url}"
        test_database_name="$(get_database_name_from_url "${test_database_url}")"

        if [[ "${test_database_name}" != "agent_ca_test" ]]; then
            echo "[ERROR] TEST_DATABASE_URL 必须指向专用测试数据库 agent_ca_test，当前为：${test_database_name}" >&2
            exit 1
        fi

        if [[ -n "${development_database_url}" ]]; then
            development_database_name="$(get_database_name_from_url "${development_database_url}")"
            if [[ "${development_database_name}" == "${test_database_name}" ]]; then
                echo "[ERROR] TEST_DATABASE_URL 不能与开发库 DATABASE_URL 指向同一个数据库：${test_database_name}" >&2
                exit 1
            fi
        fi
    }

    case "${action}" in
        help|"")
            print_help
            ;;
        env)
            if [[ -f .env ]]; then
                echo "[INFO]  .env 已存在，跳过生成。"
            elif [[ -f .env.example ]]; then
                cp .env.example .env
                echo "[INFO]  已根据 .env.example 生成 .env。"
            else
                echo "[ERROR] 未找到 .env.example，无法生成 .env。" >&2
                exit 1
            fi
            ;;
        sync)
            UV_MANAGED_PYTHON=1 uv python install 3.14
            UV_MANAGED_PYTHON=1 uv sync --python 3.14 --managed-python
            ;;
        hooks)
            install_git_hooks
            ;;
        certs)
            ensure_ca_material
            ;;
        migrate)
            migrate_target="app"
            set -- {{args}}
            if [[ $# -gt 1 ]]; then
                echo "[ERROR] just prep migrate 只接受一个可选目标参数：app 或 test。" >&2
                exit 2
            fi
            if [[ $# -eq 1 ]]; then
                if [[ "$1" != "app" && "$1" != "test" ]]; then
                    echo "[ERROR] just prep migrate 仅支持 app 或 test，当前为：$1" >&2
                    exit 2
                fi
                migrate_target="$1"
            fi

            if [[ "${migrate_target}" == "app" ]]; then
                uv run alembic upgrade head
            else
                test_database_url="$(resolve_test_database_url)"
                development_database_url="$(resolve_development_database_url)"
                validate_test_database_url "${test_database_url}" "${development_database_url}"
                APP_ENV=testing DATABASE_URL="${test_database_url}" TEST_DATABASE_URL="${test_database_url}" uv run alembic upgrade head
            fi
            ;;
        *)
            echo "[ERROR] 未知 prep action: ${action}" >&2
            exit 2
            ;;
    esac

app action='start' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    host="{{app_host}}"
    port="{{app_port}}"
    pid_file="{{app_pid_file}}"
    log_file="{{app_log_file}}"
    app_module="{{app_module}}"
    health_url="http://127.0.0.1:${port}/health"

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    ensure_log_dir() {
        mkdir -p "$(dirname "${pid_file}")"
    }

    read_pid() {
        if [[ -f "${pid_file}" ]]; then
            tr -d '[:space:]' < "${pid_file}"
        fi
    }

    is_running() {
        local pid="$1"
        [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
    }

    cleanup_stale_pid() {
        local pid
        pid="$(read_pid || true)"
        if [[ -n "${pid}" ]] && ! is_running "${pid}"; then
            rm -f "${pid_file}"
            echo "[WARN]  检测到 stale pid ${pid}，已移除 ${pid_file}。" >&2
        fi
    }

    wait_for_health() {
        local pid="$1"
        local attempt

        if ! command -v curl >/dev/null 2>&1; then
            sleep 2
            is_running "${pid}"
            return
        fi

        for attempt in {1..30}; do
            if curl -fsS "${health_url}" >/dev/null 2>&1; then
                return 0
            fi

            if ! is_running "${pid}"; then
                return 1
            fi

            sleep 1
        done

        return 1
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate app
            ;;
        start)
            just doctor
            ensure_log_dir
            background=1
            if [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "fg" ]]; then
                background=0
                requested_args=("${requested_args[@]:1}")
            elif [[ "${#requested_args[@]}" -gt 0 ]] && [[ "${requested_args[0]}" == "bg" ]]; then
                background=1
                requested_args=("${requested_args[@]:1}")
            fi

            if [[ "${background}" -eq 1 ]]; then
                cleanup_stale_pid
                existing_pid="$(read_pid || true)"
                if is_running "${existing_pid}"; then
                    echo "[INFO]  {{project_name}} 已在后台运行（pid=${existing_pid}）。"
                    exit 0
                fi

                if [[ "${#requested_args[@]}" -gt 0 ]]; then
                    nohup uv run uvicorn "${app_module}" --reload --host "${host}" --port "${port}" "${requested_args[@]}" >"${log_file}" 2>&1 &
                else
                    nohup uv run uvicorn "${app_module}" --reload --host "${host}" --port "${port}" >"${log_file}" 2>&1 &
                fi
                pid="$!"
                printf '%s\n' "${pid}" > "${pid_file}"

                if wait_for_health "${pid}"; then
                    echo "[INFO]  {{project_name}} 已在后台启动（pid=${pid}）。"
                    echo "[INFO]  日志文件：${log_file}"
                else
                    echo "[ERROR] {{project_name}} 后台启动失败，请检查日志：${log_file}" >&2
                    if is_running "${pid}"; then
                        kill "${pid}" 2>/dev/null || true
                        wait "${pid}" 2>/dev/null || true
                    fi
                    rm -f "${pid_file}"
                    exit 1
                fi
            else
                echo "[INFO]  启动 {{project_name}}（前台，热重载）..."
                echo "[INFO]  OpenAPI 文档：http://localhost:${port}/docs"
                echo "[INFO]  健康检查：${health_url}"
                if [[ "${#requested_args[@]}" -gt 0 ]]; then
                    exec uv run uvicorn "${app_module}" --reload --host "${host}" --port "${port}" "${requested_args[@]}"
                fi

                exec uv run uvicorn "${app_module}" --reload --host "${host}" --port "${port}"
            fi
            ;;
        stop)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if ! is_running "${pid}"; then
                rm -f "${pid_file}"
                echo "[INFO]  {{project_name}} 当前没有后台实例。"
                exit 0
            fi

            kill "${pid}" 2>/dev/null || true
            wait "${pid}" 2>/dev/null || true
            rm -f "${pid_file}"
            echo "[INFO]  已停止 {{project_name}} 后台实例（pid=${pid}）。"
            ;;
        status)
            cleanup_stale_pid
            pid="$(read_pid || true)"
            if is_running "${pid}"; then
                echo "[INFO]  {{project_name}} 正在运行（pid=${pid}）。"
            else
                echo "[INFO]  {{project_name}} 当前未运行。"
            fi
            ;;
        logs)
            ensure_log_dir
            if [[ ! -f "${log_file}" ]]; then
                echo "[ERROR] 未找到日志文件：${log_file}" >&2
                exit 1
            fi

            if [[ "${args_string}" == "follow" ]]; then
                exec tail -f "${log_file}"
            fi

            tail -n 200 "${log_file}"
            ;;
        restart)
            just app stop
            if [[ -z "${args_string}" ]] || [[ "${args_string}" == "bg" ]]; then
                just app start
            else
                echo "[ERROR] app restart 只管理后台实例；如需前台运行，请直接执行 just app start fg。" >&2
                exit 2
            fi
            ;;
        *)
            echo "[ERROR] 未知 app action: ${action}" >&2
            exit 2
            ;;
    esac

test action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"
    args_string="{{args}}"
    host="{{test_server_host}}"
    app_module="{{app_module}}"
    default_test_database_url="{{default_test_database_url}}"
    test_server_pid=""
    test_server_log=""
    test_server_base_url=""

    requested_args=()
    if [[ -n "${args_string}" ]]; then
        read -r -a requested_args <<< "${args_string}"
    fi

    load_dotenv() {
        if [[ -f .env ]]; then
            set -a
            source .env
            set +a
        fi
    }

    run_venv_python() {
        uv run --no-sync python "$@"
    }

    validate_database_url_value() {
        local variable_name="$1"
        local database_url="$2"

        if [[ -z "${database_url}" ]]; then
            echo "[ERROR] ${variable_name} 未配置，请检查 .env 文件。" >&2
            exit 1
        fi

        if ! run_venv_python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); ok = bool(parts.scheme and parts.username and parts.password not in (None, "") and parts.hostname and parts.path and parts.path != "/"); raise SystemExit(0 if ok else 1)' "${database_url}"; then
            echo "[ERROR] ${variable_name} 配置不完整，请参考 .env.example 使用带用户名、密码、主机和数据库名的完整 URL。" >&2
            exit 1
        fi
    }

    get_database_name_from_url() {
        run_venv_python -c 'from urllib.parse import urlsplit; import re, sys; database_name = urlsplit(sys.argv[1]).path.lstrip("/"); valid = bool(database_name) and re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", database_name) is not None; sys.stdout.write(database_name + "\n") if valid else sys.exit(1)' "$1"
    }

    resolve_test_database_url() {
        load_dotenv

        if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
            printf '%s\n' "${TEST_DATABASE_URL}"
            return
        fi

        printf '%s\n' "${default_test_database_url}"
    }

    resolve_development_database_url() {
        load_dotenv
        printf '%s\n' "${DATABASE_URL:-}"
    }

    validate_test_e2e_base_url() {
        local base_url="$1"

        if ! run_venv_python -c 'from urllib.parse import urlsplit; import sys; parts = urlsplit(sys.argv[1]); host = parts.hostname or ""; ok = parts.scheme in {"http", "https"} and host in {"127.0.0.1", "localhost"} and parts.port is not None and parts.path in {"", "/"}; raise SystemExit(0 if ok else 1)' "${base_url}"; then
            echo "[ERROR] TEST_E2E_BASE_URL 必须是指向本地临时测试实例的完整 URL，例如：http://127.0.0.1:19123。" >&2
            exit 1
        fi
    }

    find_free_port() {
        run_venv_python -c 'import socket; sock = socket.socket(); sock.bind(("127.0.0.1", 0)); print(sock.getsockname()[1]); sock.close()'
    }

    validate_test_database_url() {
        local test_database_url="$1"
        local development_database_url="$2"
        local test_database_name

        validate_database_url_value "TEST_DATABASE_URL" "${test_database_url}"
        test_database_name="$(get_database_name_from_url "${test_database_url}")"

        if [[ "${test_database_name}" != "agent_ca_test" ]]; then
            echo "[ERROR] TEST_DATABASE_URL 必须指向专用测试数据库 agent_ca_test，当前为：${test_database_name}" >&2
            exit 1
        fi

        if [[ -n "${development_database_url}" ]]; then
            development_database_name="$(get_database_name_from_url "${development_database_url}")"
            if [[ "${development_database_name}" == "${test_database_name}" ]]; then
                echo "[ERROR] TEST_DATABASE_URL 不能与开发库 DATABASE_URL 指向同一个数据库：${test_database_name}" >&2
                exit 1
            fi
        fi
    }

    check_test_database_connectivity() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" uv run python -c 'import os, psycopg; from sqlalchemy.engine import make_url; url = make_url(os.environ["TEST_DATABASE_URL"]); conn = psycopg.connect(host=url.host, port=url.port or 5432, user=url.username, password=url.password, dbname=url.database); cur = conn.cursor(); cur.execute("SELECT 1"); cur.fetchone(); cur.close(); conn.close()' >/dev/null 2>&1; then
            echo "[ERROR] 测试数据库不可连接；请确认共享测试库已就绪，并检查 TEST_DATABASE_URL。" >&2
            exit 1
        fi
    }

    check_test_database_schema_ready() {
        local test_database_url="$1"

        if ! TEST_DATABASE_URL="${test_database_url}" uv run python -c 'import os, psycopg; from sqlalchemy.engine import make_url; url = make_url(os.environ["TEST_DATABASE_URL"]); conn = psycopg.connect(host=url.host, port=url.port or 5432, user=url.username, password=url.password, dbname=url.database); cur = conn.cursor(); cur.execute("SELECT version_num FROM alembic_version LIMIT 1"); row = cur.fetchone(); cur.close(); conn.close(); raise SystemExit(0 if row and row[0] else 1)' >/dev/null 2>&1; then
            echo "[ERROR] 测试数据库 schema 未准备好，请先执行 just test bootstrap 或 just prep migrate test。" >&2
            exit 1
        fi
    }

    run_test_doctor() {
        local test_database_url
        local development_database_url

        SKIP_DATABASE_URL_DOCTOR=1 just doctor
        test_database_url="$(resolve_test_database_url)"
        development_database_url="$(resolve_development_database_url)"
        validate_test_database_url "${test_database_url}" "${development_database_url}"
        check_test_database_connectivity "${test_database_url}"
        check_test_database_schema_ready "${test_database_url}"
    }

    run_scoped_pytest() {
        local default_path="$1"
        shift
        local selection=("$@")

        if [[ "${#selection[@]}" -eq 0 ]]; then
            uv run pytest "${default_path}"
            return
        fi

        if [[ "${selection[0]}" == -* ]]; then
            uv run pytest "${default_path}" "${selection[@]}"
            return
        fi

        uv run pytest "${selection[@]}"
    }

    run_requested_tests() {
        local default_path="$1"

        if [[ "${#requested_args[@]}" -gt 0 ]]; then
            TEST_E2E_BASE_URL="${test_server_base_url:-${TEST_E2E_BASE_URL:-}}" run_scoped_pytest "${default_path}" "${requested_args[@]}"
            return
        fi

        TEST_E2E_BASE_URL="${test_server_base_url:-${TEST_E2E_BASE_URL:-}}" run_scoped_pytest "${default_path}"
    }

    stop_test_server() {
        if [[ -n "${test_server_pid}" ]] && kill -0 "${test_server_pid}" 2>/dev/null; then
            kill "${test_server_pid}" 2>/dev/null || true
            wait "${test_server_pid}" 2>/dev/null || true
            echo "[INFO]  已停止临时测试实例。"
        fi

        if [[ -n "${test_server_log}" ]] && [[ -f "${test_server_log}" ]]; then
            rm -f "${test_server_log}"
        fi
    }

    wait_for_test_server() {
        local attempt

        for attempt in {1..30}; do
            if curl -fsS "${test_server_base_url}/health" >/dev/null 2>&1; then
                return 0
            fi

            if ! kill -0 "${test_server_pid}" 2>/dev/null; then
                echo "[ERROR] 临时测试实例启动失败。" >&2
                cat "${test_server_log}" >&2
                return 1
            fi

            sleep 1
        done

        echo "[ERROR] 等待临时测试实例就绪超时：${test_server_base_url}" >&2
        cat "${test_server_log}" >&2
        return 1
    }

    start_test_server() {
        local test_database_url="$1"
        local test_server_port
        local test_admin_token
        local test_internal_token

        test_admin_token="${CA_SERVER_ADMIN_API_TOKEN:-test-ca-admin-token}"
        test_internal_token="${CA_SERVER_INTERNAL_API_TOKEN:-test-ca-internal-token}"

        test_server_port="$(find_free_port)"
        test_server_base_url="http://${host}:${test_server_port}"
        validate_test_e2e_base_url "${test_server_base_url}"
        test_server_log="$(mktemp "${TMPDIR:-/tmp}/ca-server-test.XXXXXX.log")"

        echo "[INFO]  启动临时测试实例：${test_server_base_url}"

        APP_ENV=testing \
        DATABASE_URL="${test_database_url}" \
        TEST_DATABASE_URL="${test_database_url}" \
        CA_SERVER_ADMIN_API_TOKEN="${test_admin_token}" \
        CA_SERVER_INTERNAL_API_TOKEN="${test_internal_token}" \
        uv run uvicorn "${app_module}" --host "${host}" --port "${test_server_port}" >"${test_server_log}" 2>&1 &
        test_server_pid="$!"
        wait_for_test_server
    }

    case "${action}" in
        bootstrap)
            just _bootstrap_common
            just prep migrate test
            echo "[INFO]  测试环境准备完成。"
            ;;
        unit)
            if [[ "${#requested_args[@]}" -eq 0 ]]; then
                uv run pytest tests/unit/ --cov=app --cov-report=term-missing --cov-fail-under=0
            elif [[ "${requested_args[0]}" == -* ]]; then
                uv run pytest tests/unit/ "${requested_args[@]}" --cov=app --cov-report=term-missing --cov-fail-under=0
            else
                uv run pytest "${requested_args[@]}" --cov=app --cov-report=term-missing --cov-fail-under=0
            fi
            ;;
        coverage)
            if [[ "${#requested_args[@]}" -eq 0 ]]; then
                uv run pytest tests/unit/ --cov=app --cov-report=term-missing --cov-fail-under=70
            elif [[ "${requested_args[0]}" == -* ]]; then
                uv run pytest tests/unit/ "${requested_args[@]}" --cov=app --cov-report=term-missing --cov-fail-under=70
            else
                uv run pytest "${requested_args[@]}" --cov=app --cov-report=term-missing --cov-fail-under=70
            fi
            ;;
        integration)
            run_test_doctor
            run_requested_tests tests/integration/
            ;;
        e2e)
            run_test_doctor
            test_database_url="$(resolve_test_database_url)"
            trap stop_test_server EXIT
            start_test_server "${test_database_url}"
            run_requested_tests tests/e2e/
            ;;
        all)
            just test unit
            just test integration
            just test e2e
            ;;
        *)
            echo "[ERROR] 未知 test action: ${action}" >&2
            exit 2
            ;;
    esac

qa action='all' *args:
    #!/usr/bin/env bash
    set -eu -o pipefail
    action="{{action}}"

    case "${action}" in
        all)
            just qa fix
            just qa precommit
            just qa audit
            ;;
        fmt)
            uv run ruff format .
            ;;
        fix)
            uv run ruff format .
            uv run ruff check . --fix
            ;;
        precommit)
            uv run pre-commit run --all-files
            ;;
        audit)
            uv run pip-audit
            ;;
        *)
            echo "[ERROR] 未知 qa action: ${action}" >&2
            exit 2
            ;;
    esac
